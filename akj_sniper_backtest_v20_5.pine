//@version=6
strategy("AKJ 2.0 Backtest-Engine v20.7", overlay=true, initial_capital=50000, default_qty_type=strategy.cash, commission_type=strategy.commission.cash_per_order, commission_value=2.0, slippage=1, calc_on_every_tick=true)

// ==========================================
// --- 1. INPUTS ---
// ==========================================
group_rm         = "Risikomanagement"
risk_per_trade   = input.float(150.0, "Basis Risiko pro Trade (€)", group=group_rm)
limit_offset_pct = input.float(0.2, "Limit-Offset (%)", group=group_rm)
use_dyn_risk     = input.bool(true, "Asymmetrisches Risk (Alpha/Delta/Omega)", group=group_rm)

group_strat      = "MK-Strategie Parameter"
bb_len           = input.int(10, "Bollinger Länge", group=group_strat)
bb_mult          = input.float(1.0, "Bollinger Multiplikator", group=group_strat)
wpr_len          = input.int(4, "Williams %R Länge", group=group_strat)
atr_len          = input.int(14, "ATR Länge (Filter)", group=group_strat)
ema_exit         = input.int(21, "Trailing Stop EMA", group=group_strat)

group_vol_filter    = "Volumen Filter (v20.7 ATR-Normalisiert)"
vol_timeframe       = input.timeframe("240", "Volumen Timeframe (4H)", group=group_vol_filter)
backtest_flex_mode  = input.bool(true, "Backtest-Modus (Lockerere Filter)", group=group_vol_filter)
// v20.7: ATR-normalisierte Schwellenwerte
feuer_atr_mult      = input.float(0.75, "Stop-Mauer Faktor FEUER (× ATR%)",  group=group_vol_filter, step=0.05, minval=0.1)
golden_atr_mult     = input.float(1.50, "Stop-Mauer Faktor GOLDEN (× ATR%)", group=group_vol_filter, step=0.05, minval=0.1)
max_tp_density      = input.float(15.0, "Max. TP-Widerstand (%) (FEUER)",    group=group_vol_filter)
golden_tp_density   = input.float(8.0,  "Max. TP-Widerstand (%) (GOLDEN)",   group=group_vol_filter)

// ==========================================
// --- ATR & Atmendes Risiko-Regime ---
// ==========================================
atr_val = ta.atr(atr_len)
// v20.7: ATR-Normalisierung
float atr_pct            = close > 0 ? (atr_val / close) * 100 : 2.0
float dyn_min_stop_feuer  = feuer_atr_mult  * atr_pct
float dyn_min_stop_golden = golden_atr_mult * atr_pct
vix_c = request.security("CBOE:VIX", "1D", close, lookahead=barmerge.lookahead_off)

// Risk Multiplikator (100% vs 25% vs 0%)
float risk_mult_l = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 0.25 : 0.0)
float risk_mult_s = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 1.0  : 0.0)

float active_risk_l = use_dyn_risk ? risk_per_trade * risk_mult_l : risk_per_trade
float active_risk_s = use_dyn_risk ? risk_per_trade * risk_mult_s : risk_per_trade

bool firewall_l = use_dyn_risk and risk_mult_l == 0.0
bool firewall_s = use_dyn_risk and risk_mult_s == 0.0

dyn_shares_l(float entry_p, float stop_p) =>
    float r = math.abs(entry_p - stop_p)
    r > 0 ? math.floor(active_risk_l / r) : 0

dyn_shares_s(float entry_p, float stop_p) =>
    float r = math.abs(entry_p - stop_p)
    r > 0 ? math.floor(active_risk_s / r) : 0

// ==========================================
// --- 2. TREND & WEINSTEIN STAGE ---
// ==========================================
f_bb_w_hist() => 
    basis = ta.sma(close, bb_len)
    dev = ta.stdev(close, bb_len) * bb_mult
    [close[1], basis[1] + dev[1], basis[1] - dev[1], close[2], basis[2] + dev[2], basis[2] - dev[2], ta.sma(close, 30)[1], ta.sma(close, 30)[2]]

[w_cl_1, w_up_1, w_lo_1, w_cl_2, w_up_2, w_lo_2, w_sma30_1, w_sma30_2] = request.security(syminfo.tickerid, "W", f_bb_w_hist(), lookahead=barmerge.lookahead_off)
float w_basis_1 = request.security(syminfo.tickerid, "W", ta.sma(close, bb_len)[1], lookahead=barmerge.lookahead_off) // Fix v20.6: Wochenmittellinie für Midline-Reset

var int w_trend = 0 
if w_cl_1 > w_up_1 and w_cl_2 > w_up_2
    w_trend := 1
else if w_cl_1 < w_lo_1 and w_cl_2 < w_lo_2
    w_trend := -1
else if w_trend == 1 and w_cl_1 < w_basis_1  // Fix v20.6: Midline-Reset – Trend pausiert wenn Wochenkurs unter Basis fällt
    w_trend := 0
else if w_trend == -1 and w_cl_1 > w_basis_1  // Fix v20.6: Midline-Reset – Trend pausiert wenn Wochenkurs über Basis steigt
    w_trend := 0

int weinstein_stage = 0
if w_cl_1 > w_sma30_1 and w_sma30_1 > w_sma30_2
    weinstein_stage := 2
else if w_cl_1 < w_sma30_1 and w_sma30_1 < w_sma30_2
    weinstein_stage := 4

var int stage_change_bar = bar_index
if ta.change(weinstein_stage) != 0
    stage_change_bar := bar_index
int anchor_bars = math.max(1, bar_index - stage_change_bar)

// ==========================================
// --- 3. TAGES-LOGIK & TRIGGER ---
// ==========================================
[d_basis, d_up, d_lo] = ta.bb(close, bb_len, bb_mult)
atr_buffer = atr_val * 0.2

var bool setup_strict_long = false
var bool setup_strict_short = false

if close[1] > d_up[1] + atr_buffer and close[2] > d_up[2] + atr_buffer
    setup_strict_long := true
if close[1] < d_lo[1] - atr_buffer and close[2] < d_lo[2] - atr_buffer
    setup_strict_short := true

if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_long := false
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_short := false
// Scharf-Modus bleibt bis zum unteren Band aktiv (80% Dip-Käufer). Guard entfernt in v20.6b.

d_wpr = math.abs(ta.wpr(wpr_len))
bool is_doji = math.abs(close - open) < (atr_val * 0.1)
float ema21 = ta.ema(close, ema_exit)

float atr_stop_dist = atr_val * 1.0 // v20.6: ATR Stop auf 1.0 reduziert

float sp_long  = high
float sl_long  = low - atr_stop_dist
float tp_long  = sp_long + (sp_long - sl_long)

float sp_short = low
float sl_short = high + atr_stop_dist
float tp_short = sp_short - (sl_short - sp_short)

// ==========================================
// ==========================================
// --- 4. VOLUMEN-STRUKTUR (Hintergrund-Radar) ---
// ==========================================

f_calc_tf_vol_anchored(sp, sl, tp, lookback) =>
    float s_dens = 0.0, float t_dens = 0.0, float avg_v = 0.0
    float zone_vol_s = 0.0, float zone_vol_t = 0.0, float total_v = 0.0
    float upper_s = math.max(sp, sl), float lower_s = math.min(sp, sl)
    float upper_t = math.max(sp, tp), float lower_t = math.min(sp, tp)
    int lb = math.min(lookback, 300)
    
    if lb > 0
        for i = 0 to lb - 1
            float bar_h = high[i], float bar_l = low[i], float bar_vol = volume[i]
            total_v += bar_vol
            float bar_range = bar_h - bar_l
            if bar_range > 0
                float intersect_s = math.max(0, math.min(bar_h, upper_s) - math.max(bar_l, lower_s))
                zone_vol_s += bar_vol * (intersect_s / bar_range)
                float intersect_t = math.max(0, math.min(bar_h, upper_t) - math.max(bar_l, lower_t))
                zone_vol_t += bar_vol * (intersect_t / bar_range)
        avg_v := total_v / lb
        if total_v > 0
            s_dens := (zone_vol_s / total_v) * 100
            t_dens := (zone_vol_t / total_v) * 100

    [s_dens, t_dens, avg_v]

[stop_density_l, tp_density_l, avg_anchor_vol_l] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_long, sl_long, tp_long, anchor_bars))
[stop_density_s, tp_density_s, avg_anchor_vol_s] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_short, sl_short, tp_short, anchor_bars))

lower_tf_vol_arr = request.security_lower_tf(syminfo.tickerid, vol_timeframe, volume)
float current_bar_lower_vol = array.size(lower_tf_vol_arr) > 0 ? array.sum(lower_tf_vol_arr) : volume 

float rld_pct_l = avg_anchor_vol_l > 0 ? (current_bar_lower_vol / avg_anchor_vol_l) * 100 : 0
float rld_pct_s = avg_anchor_vol_s > 0 ? (current_bar_lower_vol / avg_anchor_vol_s) * 100 : 0

// Vakuum-Condition basiert nun auf reiner TP-Weitsicht, RLD entkoppelt
// v20.7: ATR-normalisierte Schwellenwerte
bool vol_feuer_l  = stop_density_l >= dyn_min_stop_feuer  and tp_density_l <= max_tp_density
bool vol_feuer_s  = stop_density_s >= dyn_min_stop_feuer  and tp_density_s <= max_tp_density
bool vol_golden_l = stop_density_l >= dyn_min_stop_golden and tp_density_l <= golden_tp_density
bool vol_golden_s = stop_density_s >= dyn_min_stop_golden and tp_density_s <= golden_tp_density

bool long_trigger_70  = d_wpr >= 70 and close < open and not is_doji and close > d_lo
bool long_trigger_80  = d_wpr >= 80 and close < open and not is_doji and close > d_lo
bool short_trigger_30 = d_wpr <= 30 and close > open and not is_doji and close < d_up
bool short_trigger_20 = d_wpr <= 20 and close > open and not is_doji and close < d_up

// ==========================================
// --- 5. FUNNEL & STATUS-AUDIT SYSTEM (v20.5) ---
// ==========================================
type VirtualTrade
    int   t_class     // 2 = Feuer, 3 = Golden
    int   dir         // 1 = Long, -1 = Short
    float ep          // Entry-Preis
    float sl          // Stop-Loss
    float tp          // Take-Profit (1:1)
    float r_dist      // Risiko-Distanz (|EP-SL|)
    float risk_eur    // Risiko in € bei Einstieg
    bool  tp1_hit     // Wurde 1:1 schon erreicht?
    int   entry_bar   // Bar-Index bei Einstieg

var virtual_trades = array.new<VirtualTrade>()

// ---- ALARM-ZAEHLER (wie oft hat das Signal gebimmelt?) ----
var int alarms_feuer_l  = 0   // Wie oft FEUER LONG Alarm ausgelöst
var int alarms_feuer_s  = 0   // Wie oft FEUER SHORT Alarm ausgelöst
var int alarms_golden_l = 0   // Wie oft GOLDEN LONG Alarm ausgelöst
var int alarms_golden_s = 0   // Wie oft GOLDEN SHORT Alarm ausgelöst

// ---- TRADE-ERGEBNIS-ZAEHLER (was ist passiert wenn wir die Order gesetzt hätten?) ----
var int w_feuer_l  = 0  // FEUER LONG  Gewinne
var int l_feuer_l  = 0  // FEUER LONG  Verluste
var int w_feuer_s  = 0  // FEUER SHORT Gewinne
var int l_feuer_s  = 0  // FEUER SHORT Verluste
var int w_golden_l = 0  // GOLDEN LONG  Gewinne
var int l_golden_l = 0  // GOLDEN LONG  Verluste
var int w_golden_s = 0  // GOLDEN SHORT Gewinne
var int l_golden_s = 0  // GOLDEN SHORT Verluste

// ---- GEWINN/VERLUST IN € ----
var float eur_total_feuer_l  = 0.0
var float eur_total_feuer_s  = 0.0
var float eur_total_golden_l = 0.0
var float eur_total_golden_s = 0.0

// ---- LEGACY-ZAEHLER für R-Tracking ----
var int   w_lauern = 0, var int   l_lauern = 0
var float p_lauern = 0.0
var int   total_missed_omega = 0

// Definition der Audit-Level (Zero-Latency Sync Logik)
bool is_radar_l = high >= d_up + (atr_val * 0.2)
bool radar_state_l = weinstein_stage == 2 and (is_radar_l or setup_strict_long)
bool is_radar_s = low <= d_lo - (atr_val * 0.2)
bool radar_state_s = weinstein_stage == 4 and (is_radar_s or setup_strict_short)

bool raw_feuer_l   = radar_state_l and setup_strict_long and long_trigger_80
bool raw_feuer_s   = radar_state_s and setup_strict_short and short_trigger_20

// v20.7: RS-Veto für Golden — brauchen perf_diff aus Sektor-Vergleich
// Im Backtest: kein Sektor-Request (Performance), RS-Veto optional via Input
bool rs_ok_for_premium = true  // Backtest: RS-Veto deaktiviert (kein Sektor-Request verfügbar ohne 6. call)

bool trigger_lauern_l = radar_state_l and long_trigger_70
bool trigger_feuer_l  = raw_feuer_l   and vol_feuer_l
bool trigger_golden_l = raw_feuer_l   and vol_golden_l and rs_ok_for_premium

bool trigger_lauern_s = radar_state_s and short_trigger_30
bool trigger_feuer_s  = raw_feuer_s   and vol_feuer_s
bool trigger_golden_s = raw_feuer_s   and vol_golden_s and rs_ok_for_premium

// Evaluierung offener virtueller Trades
if array.size(virtual_trades) > 0
    for i = array.size(virtual_trades) - 1 to 0
        VirtualTrade vt = array.get(virtual_trades, i)

        bool sl_hit      = false
        bool tp_hit      = false
        bool runner_exit = false
        bool time_exit   = (bar_index - vt.entry_bar) >= 5

        if vt.dir == 1
            if low  <= vt.sl then sl_hit      := true
            if not vt.tp1_hit and high >= vt.tp then tp_hit := true
            if vt.tp1_hit and (close < ema21 or w_trend == -1 or time_exit) then runner_exit := true
        else
            if high >= vt.sl then sl_hit      := true
            if not vt.tp1_hit and low  <= vt.tp then tp_hit := true
            if vt.tp1_hit and (close > ema21 or w_trend == 1 or time_exit)  then runner_exit := true

        // Pessimistischer Ansatz: Wenn beides, SL gewinnt
        if sl_hit and tp_hit
            tp_hit := false

        if not vt.tp1_hit
            if sl_hit or (time_exit and not tp_hit)
                // VERLUST: -1R = -risk_eur
                float pnl_eur = -vt.risk_eur
                if vt.t_class == 2 and vt.dir == 1
                    l_feuer_l  += 1 
                    eur_total_feuer_l  += pnl_eur
                else if vt.t_class == 2 and vt.dir == -1
                    l_feuer_s  += 1
                    eur_total_feuer_s  += pnl_eur
                else if vt.t_class == 3 and vt.dir == 1
                    l_golden_l += 1
                    eur_total_golden_l += pnl_eur
                else if vt.t_class == 3 and vt.dir == -1
                    l_golden_s += 1
                    eur_total_golden_s += pnl_eur
                else
                    l_lauern += 1
                    p_lauern -= 1.0
                array.remove(virtual_trades, i)

            else if tp_hit
                // TP1 erreicht: 50% Gewinn (+0.5R), restliche 50% laufen
                if vt.t_class == 2 and vt.dir == 1
                    w_feuer_l  += 1
                else if vt.t_class == 2 and vt.dir == -1
                    w_feuer_s  += 1
                else if vt.t_class == 3 and vt.dir == 1
                    w_golden_l += 1
                else if vt.t_class == 3 and vt.dir == -1
                    w_golden_s += 1
                else
                    w_lauern += 1
                vt.tp1_hit := true
                vt.sl      := vt.ep  // Stop auf Break-Even
        else
            // Runner-Phase: Exit bei EMA/Trend/Zeit
            if sl_hit or runner_exit
                float exit_p = sl_hit ? vt.sl : close
                float exit_r = vt.dir == 1 ? (exit_p - vt.ep) / vt.r_dist : (vt.ep - exit_p) / vt.r_dist
                // Gesamt-P&L: 50% zu 1R gesichert + 50% Runner-Ergebnis
                float total_r   = (0.5 * 1.0) + (0.5 * math.max(0.0, exit_r))
                float pnl_eur = total_r * vt.risk_eur

                if vt.t_class == 2 and vt.dir == 1
                    eur_total_feuer_l  += pnl_eur
                else if vt.t_class == 2 and vt.dir == -1
                    eur_total_feuer_s  += pnl_eur
                else if vt.t_class == 3 and vt.dir == 1
                    eur_total_golden_l += pnl_eur
                else if vt.t_class == 3 and vt.dir == -1
                    eur_total_golden_s += pnl_eur
                else
                    p_lauern += total_r
                array.remove(virtual_trades, i)

// Hilfsfunktion: prüft ob aktiver Trade der Klasse/Richtung bereits läuft
f_is_active(int t_class, int dir) =>
    bool active = false
    if array.size(virtual_trades) > 0
        for i = 0 to array.size(virtual_trades) - 1
            VirtualTrade vt = array.get(virtual_trades, i)
            if vt.t_class == t_class and vt.dir == dir
                active := true
                break
    active

// Event: Signal zum ERSTEN Mal auf diesem Bar (Flankendetektion)
bool evt_feuer_l  = trigger_feuer_l  and not trigger_feuer_l[1]
bool evt_feuer_s  = trigger_feuer_s  and not trigger_feuer_s[1]
bool evt_golden_l = trigger_golden_l and not trigger_golden_l[1]
bool evt_golden_s = trigger_golden_s and not trigger_golden_s[1]
bool evt_lauern_l = radar_state_l    and long_trigger_70 and not (radar_state_l[1] and long_trigger_70[1])
bool evt_lauern_s = radar_state_s    and short_trigger_30 and not (radar_state_s[1] and short_trigger_30[1])

// ---- ALARM-ZAEHLER erhöhen ---
if evt_feuer_l
    alarms_feuer_l  += 1
if evt_feuer_s
    alarms_feuer_s  += 1
if evt_golden_l
    alarms_golden_l += 1
if evt_golden_s
    alarms_golden_s += 1

// ---- Neue Trades in den Simulator einspeisen ----
float cur_risk_l = not firewall_l ? active_risk_l : 0.0
float cur_risk_s = not firewall_s ? active_risk_s : 0.0

if evt_feuer_l and not f_is_active(2, 1) and cur_risk_l > 0
    array.push(virtual_trades, VirtualTrade.new(2, 1, sp_long, sl_long, tp_long, sp_long - sl_long, cur_risk_l, false, bar_index))
if evt_feuer_s and not f_is_active(2, -1) and cur_risk_s > 0
    array.push(virtual_trades, VirtualTrade.new(2, -1, sp_short, sl_short, tp_short, sl_short - sp_short, cur_risk_s, false, bar_index))
if evt_golden_l and not f_is_active(3, 1) and cur_risk_l > 0
    array.push(virtual_trades, VirtualTrade.new(3, 1, sp_long, sl_long, tp_long, sp_long - sl_long, cur_risk_l, false, bar_index))
if evt_golden_s and not f_is_active(3, -1) and cur_risk_s > 0
    array.push(virtual_trades, VirtualTrade.new(3, -1, sp_short, sl_short, tp_short, sl_short - sp_short, cur_risk_s, false, bar_index))
if evt_lauern_l and not f_is_active(1, 1)
    array.push(virtual_trades, VirtualTrade.new(1, 1, sp_long, sl_long, tp_long, sp_long - sl_long, cur_risk_l, false, bar_index))
if evt_lauern_s and not f_is_active(1, -1)
    array.push(virtual_trades, VirtualTrade.new(1, -1, sp_short, sl_short, tp_short, sl_short - sp_short, cur_risk_s, false, bar_index))

// ==========================================
// --- 6. SIGNAL-PERFORMANCE REPORT ---
// ==========================================
// Tabelle: 8 Spalten × 10 Zeilen
var table rpt = table.new(position.top_center, 8, 10,
     border_width   = 1,
     border_color   = color.rgb(50,50,50),
     frame_width    = 2,
     frame_color    = color.rgb(80,80,80))

if barstate.islast
    // Berechnungen
    int   tot_feuer_l   = w_feuer_l  + l_feuer_l
    int   tot_feuer_s   = w_feuer_s  + l_feuer_s
    int   tot_golden_l  = w_golden_l + l_golden_l
    int   tot_golden_s  = w_golden_s + l_golden_s
    int   tot_feuer     = tot_feuer_l  + tot_feuer_s
    int   tot_golden    = tot_golden_l + tot_golden_s
    int   w_feuer_tot   = w_feuer_l  + w_feuer_s
    int   w_golden_tot  = w_golden_l + w_golden_s
    int   l_feuer_tot   = l_feuer_l  + l_feuer_s
    int   l_golden_tot  = l_golden_l + l_golden_s

    float wr_fl  = tot_feuer_l  > 0 ? (w_feuer_l  / tot_feuer_l)  * 100 : 0.0
    float wr_fs  = tot_feuer_s  > 0 ? (w_feuer_s  / tot_feuer_s)  * 100 : 0.0
    float wr_gl  = tot_golden_l > 0 ? (w_golden_l / tot_golden_l) * 100 : 0.0
    float wr_gs  = tot_golden_s > 0 ? (w_golden_s / tot_golden_s) * 100 : 0.0
    float wr_f   = tot_feuer    > 0 ? (w_feuer_tot  / tot_feuer)  * 100 : 0.0
    float wr_g   = tot_golden   > 0 ? (w_golden_tot / tot_golden)  * 100 : 0.0

    float total_feuer_eur  = eur_total_feuer_l  + eur_total_feuer_s
    float total_golden_eur = eur_total_golden_l + eur_total_golden_s
    float avg_feuer_eur    = tot_feuer  > 0 ? total_feuer_eur  / tot_feuer  : 0.0
    float avg_golden_eur   = tot_golden > 0 ? total_golden_eur / tot_golden : 0.0

    // Farb-Helfer
    f_wr_bg(float wr)  => wr >= 55 ? color.rgb(0,80,0) : wr >= 50 ? color.rgb(10,50,10) : wr >= 40 ? color.rgb(50,30,0) : color.rgb(70,0,0)
    f_eur_bg(float e)  => e > 0 ? color.rgb(0,70,0) : color.rgb(70,0,0)
    f_eur_str(float e) => (e >= 0 ? "+" : "") + str.tostring(e, "#,###.##") + " €"
    f_tc(float wr)     => wr >= 50 ? color.lime : color.orange

    color COL_HDR  = color.rgb(15,15,30)
    color COL_ROW1 = color.rgb(10,10,20)
    color COL_ROW2 = color.rgb(5,5,15)
    color COL_SECT = color.rgb(20,10,40)
    color TC_HDR   = color.rgb(170,170,220)
    color TC_MAIN  = color.white
    color TC_DIM   = color.rgb(150,150,150)

    // ---- HEADER ----
    table.cell(rpt, 0, 0, "AKJ 2.0 ► Signal-Performance Report v20.7", bgcolor=color.rgb(5,5,20), text_color=color.rgb(150,180,255), text_size=size.normal)
    table.merge_cells(rpt, 0, 0, 7, 0)

    // Spalten-Header
    string[] hdrs = array.from("Signal-Typ", "🔔 Alarme", "✅ Trades", "🚀 Gewinne", "🛑 Verluste", "Win-Rate", "€ Gesamt P&L", "Ø pro Trade")
    for c = 0 to 7
        table.cell(rpt, c, 1, array.get(hdrs, c), bgcolor=COL_HDR, text_color=TC_HDR, text_size=size.small)

    // ---- FEUER FREI SECTION ----
    table.cell(rpt, 0, 2, "--- FEUER FREI LONG ---", bgcolor=COL_SECT, text_color=color.rgb(100,200,255), text_size=size.small)
    table.merge_cells(rpt, 0, 2, 7, 2)

    // FEUER LONG Zeile
    float avg_fl = tot_feuer_l > 0 ? eur_total_feuer_l / tot_feuer_l : 0.0
    table.cell(rpt, 0, 3, "🟢 FEUER LONG",        bgcolor=COL_ROW1, text_color=color.rgb(100,255,150), text_size=size.small)
    table.cell(rpt, 1, 3, str.tostring(alarms_feuer_l),  bgcolor=COL_ROW1, text_color=TC_DIM)
    table.cell(rpt, 2, 3, str.tostring(tot_feuer_l),      bgcolor=COL_ROW1, text_color=TC_MAIN)
    table.cell(rpt, 3, 3, str.tostring(w_feuer_l),        bgcolor=color.rgb(0,40,0), text_color=color.lime)
    table.cell(rpt, 4, 3, str.tostring(l_feuer_l),        bgcolor=color.rgb(40,0,0), text_color=color.orange)
    table.cell(rpt, 5, 3, str.tostring(wr_fl, "#.#") + "%", bgcolor=f_wr_bg(wr_fl), text_color=f_tc(wr_fl))
    table.cell(rpt, 6, 3, f_eur_str(eur_total_feuer_l),  bgcolor=f_eur_bg(eur_total_feuer_l), text_color=TC_MAIN)
    table.cell(rpt, 7, 3, f_eur_str(avg_fl),             bgcolor=f_eur_bg(avg_fl), text_color=TC_MAIN)

    // FEUER SHORT Zeile
    float avg_fs = tot_feuer_s > 0 ? eur_total_feuer_s / tot_feuer_s : 0.0
    table.cell(rpt, 0, 4, "🔴 FEUER SHORT",       bgcolor=COL_ROW2, text_color=color.rgb(255,120,120), text_size=size.small)
    table.cell(rpt, 1, 4, str.tostring(alarms_feuer_s),  bgcolor=COL_ROW2, text_color=TC_DIM)
    table.cell(rpt, 2, 4, str.tostring(tot_feuer_s),      bgcolor=COL_ROW2, text_color=TC_MAIN)
    table.cell(rpt, 3, 4, str.tostring(w_feuer_s),        bgcolor=color.rgb(0,40,0), text_color=color.lime)
    table.cell(rpt, 4, 4, str.tostring(l_feuer_s),        bgcolor=color.rgb(40,0,0), text_color=color.orange)
    table.cell(rpt, 5, 4, str.tostring(wr_fs, "#.#") + "%", bgcolor=f_wr_bg(wr_fs), text_color=f_tc(wr_fs))
    table.cell(rpt, 6, 4, f_eur_str(eur_total_feuer_s),  bgcolor=f_eur_bg(eur_total_feuer_s), text_color=TC_MAIN)
    table.cell(rpt, 7, 4, f_eur_str(avg_fs),             bgcolor=f_eur_bg(avg_fs), text_color=TC_MAIN)

    // FEUER GESAMT
    table.cell(rpt, 0, 5, "∑ FEUER GESAMT",    bgcolor=color.rgb(20,20,40), text_color=color.rgb(100,200,255), text_size=size.small)
    table.cell(rpt, 1, 5, str.tostring(alarms_feuer_l + alarms_feuer_s), bgcolor=color.rgb(20,20,40), text_color=TC_DIM)
    table.cell(rpt, 2, 5, str.tostring(tot_feuer),     bgcolor=color.rgb(20,20,40), text_color=TC_MAIN)
    table.cell(rpt, 3, 5, str.tostring(w_feuer_tot),   bgcolor=color.rgb(0,50,0),  text_color=color.lime)
    table.cell(rpt, 4, 5, str.tostring(l_feuer_tot),   bgcolor=color.rgb(50,0,0),  text_color=color.orange)
    table.cell(rpt, 5, 5, str.tostring(wr_f, "#.#") + "%", bgcolor=f_wr_bg(wr_f), text_color=f_tc(wr_f))
    table.cell(rpt, 6, 5, f_eur_str(total_feuer_eur),  bgcolor=f_eur_bg(total_feuer_eur), text_color=TC_MAIN)
    table.cell(rpt, 7, 5, f_eur_str(avg_feuer_eur),    bgcolor=f_eur_bg(avg_feuer_eur), text_color=TC_MAIN)

    // ---- GOLDEN SETUP SECTION ----
    table.cell(rpt, 0, 6, "--- GOLDEN SETUP ---", bgcolor=color.rgb(40,30,0), text_color=color.rgb(255,220,50), text_size=size.small)
    table.merge_cells(rpt, 0, 6, 7, 6)

    // GOLDEN LONG Zeile
    float avg_gl = tot_golden_l > 0 ? eur_total_golden_l / tot_golden_l : 0.0
    table.cell(rpt, 0, 7, "⭐ GOLDEN LONG",      bgcolor=COL_ROW1, text_color=color.rgb(255,220,50), text_size=size.small)
    table.cell(rpt, 1, 7, str.tostring(alarms_golden_l), bgcolor=COL_ROW1, text_color=TC_DIM)
    table.cell(rpt, 2, 7, str.tostring(tot_golden_l),    bgcolor=COL_ROW1, text_color=TC_MAIN)
    table.cell(rpt, 3, 7, str.tostring(w_golden_l),      bgcolor=color.rgb(0,40,0), text_color=color.lime)
    table.cell(rpt, 4, 7, str.tostring(l_golden_l),      bgcolor=color.rgb(40,0,0), text_color=color.orange)
    table.cell(rpt, 5, 7, str.tostring(wr_gl, "#.#") + "%", bgcolor=f_wr_bg(wr_gl), text_color=f_tc(wr_gl))
    table.cell(rpt, 6, 7, f_eur_str(eur_total_golden_l), bgcolor=f_eur_bg(eur_total_golden_l), text_color=TC_MAIN)
    table.cell(rpt, 7, 7, f_eur_str(avg_gl),             bgcolor=f_eur_bg(avg_gl), text_color=TC_MAIN)

    // GOLDEN SHORT Zeile
    float avg_gs = tot_golden_s > 0 ? eur_total_golden_s / tot_golden_s : 0.0
    table.cell(rpt, 0, 8, "⭐ GOLDEN SHORT",     bgcolor=COL_ROW2, text_color=color.rgb(255,180,50), text_size=size.small)
    table.cell(rpt, 1, 8, str.tostring(alarms_golden_s), bgcolor=COL_ROW2, text_color=TC_DIM)
    table.cell(rpt, 2, 8, str.tostring(tot_golden_s),    bgcolor=COL_ROW2, text_color=TC_MAIN)
    table.cell(rpt, 3, 8, str.tostring(w_golden_s),      bgcolor=color.rgb(0,40,0), text_color=color.lime)
    table.cell(rpt, 4, 8, str.tostring(l_golden_s),      bgcolor=color.rgb(40,0,0), text_color=color.orange)
    table.cell(rpt, 5, 8, str.tostring(wr_gs, "#.#") + "%", bgcolor=f_wr_bg(wr_gs), text_color=f_tc(wr_gs))
    table.cell(rpt, 6, 8, f_eur_str(eur_total_golden_s), bgcolor=f_eur_bg(eur_total_golden_s), text_color=TC_MAIN)
    table.cell(rpt, 7, 8, f_eur_str(avg_gs),             bgcolor=f_eur_bg(avg_gs), text_color=TC_MAIN)

    // GOLDEN GESAMT
    table.cell(rpt, 0, 9, "∑ GOLDEN GESAMT",    bgcolor=color.rgb(40,30,0), text_color=color.rgb(255,220,50), text_size=size.small)
    table.cell(rpt, 1, 9, str.tostring(alarms_golden_l + alarms_golden_s), bgcolor=color.rgb(40,30,0), text_color=TC_DIM)
    table.cell(rpt, 2, 9, str.tostring(tot_golden),    bgcolor=color.rgb(40,30,0), text_color=TC_MAIN)
    table.cell(rpt, 3, 9, str.tostring(w_golden_tot),  bgcolor=color.rgb(0,60,0),  text_color=color.lime)
    table.cell(rpt, 4, 9, str.tostring(l_golden_tot),  bgcolor=color.rgb(60,0,0),  text_color=color.orange)
    table.cell(rpt, 5, 9, str.tostring(wr_g, "#.#") + "%", bgcolor=f_wr_bg(wr_g), text_color=f_tc(wr_g))
    table.cell(rpt, 6, 9, f_eur_str(total_golden_eur), bgcolor=f_eur_bg(total_golden_eur), text_color=TC_MAIN)
    table.cell(rpt, 7, 9, f_eur_str(avg_golden_eur),   bgcolor=f_eur_bg(avg_golden_eur), text_color=TC_MAIN)

// ==========================================
// --- 7. STRATEGY EXEKUTION (Real Backtest) ---
// ==========================================
// PFLICHT: Ein Strategy-Script benötigt entry()-Calls zum Kompilieren. Wir feuern hier das Golden Setup ab!
if evt_golden_l and not firewall_l and strategy.position_size == 0
    strategy.entry("Long", strategy.long, qty=dyn_shares_l(sp_long, sl_long), stop=sp_long)
    strategy.exit("TP1_L", "Long", qty_percent=50, stop=sl_long, limit=tp_long)

if strategy.position_size > 0
    float be_stop = strategy.opentrades.entry_price(0)
    if close < ema21 or w_trend == -1
        strategy.close("Long", comment="Runner Out")
    else
        strategy.exit("Trail_L", "Long", stop=math.max(sl_long, be_stop))

if evt_golden_s and not firewall_s and strategy.position_size == 0
    strategy.entry("Short", strategy.short, qty=dyn_shares_s(sp_short, sl_short), stop=sp_short)
    strategy.exit("TP1_S", "Short", qty_percent=50, stop=sl_short, limit=tp_short)

if strategy.position_size < 0
    float be_stop = strategy.opentrades.entry_price(0)
    if close > ema21 or w_trend == 1
        strategy.close("Short", comment="Runner Out")
    else
        strategy.exit("Trail_S", "Short", stop=math.min(sl_short, be_stop))
