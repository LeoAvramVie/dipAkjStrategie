//@version=6
strategy("AKJ 2.0 Backtest-Engine v20.5", overlay=true, initial_capital=50000, default_qty_type=strategy.cash, commission_type=strategy.commission.cash_per_order, commission_value=2.0, slippage=1, calc_on_every_tick=true)

// ==========================================
// --- 1. INPUTS ---
// ==========================================
group_rm         = "Risikomanagement"
risk_per_trade   = input.float(150.0, "Basis Risiko pro Trade (€)", group=group_rm)
limit_offset_pct = input.float(0.2, "Limit-Offset (%)", group=group_rm)
use_dyn_risk     = input.bool(true, "Asymmetrisches Risk (Alpha/Delta/Omega)", group=group_rm)

group_strat      = "MK-Strategie Parameter"
bb_len           = input.int(10, "Bollinger Länge", group=group_strat)
bb_mult          = input.float(1.0, "Bollinger Multiplikator", group=group_strat)
wpr_len          = input.int(4, "Williams %R Länge", group=group_strat)
atr_len          = input.int(14, "ATR Länge (Filter)", group=group_strat)
ema_exit         = input.int(21, "Trailing Stop EMA", group=group_strat)

group_vol_filter = "Volumen Filter (v20.5)"
vol_timeframe    = input.timeframe("240", "Volumen Timeframe (4H)", group=group_vol_filter)
use_flex         = input.bool(true, "Backtest Flex-Mode (Signaldichte erhöhen)", group=group_vol_filter)
min_stop_density = input.float(10.0, "Min. Stop-Versicherung (%)", group=group_vol_filter)
max_tp_density   = input.float(8.0, "Max. TP-Widerstand (%)", group=group_vol_filter)
rld_limit        = input.float(20.0, "RLD Vakuum Limit (%)", group=group_vol_filter)

opt_min_stop = use_flex ? 8.0  : min_stop_density
opt_max_tp   = use_flex ? 12.0 : max_tp_density
opt_rld      = use_flex ? 30.0 : rld_limit

// ==========================================
// --- ATR & Atmendes Risiko-Regime ---
// ==========================================
atr_val = ta.atr(atr_len)
vix_c = request.security("CBOE:VIX", "1D", close, lookahead=barmerge.lookahead_off)

// Risk Multiplikator (100% vs 25% vs 0%)
float risk_mult_l = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 0.25 : 0.0)
float risk_mult_s = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 1.0  : 0.0)

float active_risk_l = use_dyn_risk ? risk_per_trade * risk_mult_l : risk_per_trade
float active_risk_s = use_dyn_risk ? risk_per_trade * risk_mult_s : risk_per_trade

bool firewall_l = use_dyn_risk and risk_mult_l == 0.0
bool firewall_s = use_dyn_risk and risk_mult_s == 0.0

dyn_shares_l(float entry_p, float stop_p) =>
    float r = math.abs(entry_p - stop_p)
    r > 0 ? math.floor(active_risk_l / r) : 0

dyn_shares_s(float entry_p, float stop_p) =>
    float r = math.abs(entry_p - stop_p)
    r > 0 ? math.floor(active_risk_s / r) : 0

// ==========================================
// --- 2. TREND & WEINSTEIN STAGE ---
// ==========================================
f_bb_w_hist() => 
    basis = ta.sma(close, bb_len)
    dev = ta.stdev(close, bb_len) * bb_mult
    [close[1], basis[1] + dev[1], basis[1] - dev[1], close[2], basis[2] + dev[2], basis[2] - dev[2], ta.sma(close, 30)[1], ta.sma(close, 30)[2]]

[w_cl_1, w_up_1, w_lo_1, w_cl_2, w_up_2, w_lo_2, w_sma30_1, w_sma30_2] = request.security(syminfo.tickerid, "W", f_bb_w_hist(), lookahead=barmerge.lookahead_off)

var int w_trend = 0 
if w_cl_1 > w_up_1 and w_cl_2 > w_up_2
    w_trend := 1
else if w_cl_1 < w_lo_1 and w_cl_2 < w_lo_2
    w_trend := -1

int weinstein_stage = 0
if w_cl_1 > w_sma30_1 and w_sma30_1 > w_sma30_2
    weinstein_stage := 2
else if w_cl_1 < w_sma30_1 and w_sma30_1 < w_sma30_2
    weinstein_stage := 4

var int stage_change_bar = bar_index
if ta.change(weinstein_stage) != 0
    stage_change_bar := bar_index
int anchor_bars = math.max(1, bar_index - stage_change_bar)

// ==========================================
// --- 3. TAGES-LOGIK & TRIGGER ---
// ==========================================
[d_basis, d_up, d_lo] = ta.bb(close, bb_len, bb_mult)
atr_buffer = atr_val * 0.2

var bool setup_strict_long = false
var bool setup_strict_short = false

if close[1] > d_up[1] + atr_buffer and close[2] > d_up[2] + atr_buffer
    setup_strict_long := true
if close[1] < d_lo[1] - atr_buffer and close[2] < d_lo[2] - atr_buffer
    setup_strict_short := true

if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_long := false
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_short := false

d_wpr = math.abs(ta.wpr(wpr_len))
bool is_doji = math.abs(close - open) < (atr_val * 0.1)
float ema21 = ta.ema(close, ema_exit)

float puffer = syminfo.mintick * 2

float sp_long  = high + puffer
float sl_long  = low - puffer
float tp_long  = sp_long + (sp_long - sl_long)

float sp_short = low - puffer
float sl_short = high + puffer
float tp_short = sp_short - (sl_short - sp_short)

// ==========================================
// --- 4. MAP AVP CACHING (Performance) ---
// ==========================================
var avp_cache = map.new<int, float>()

f_calc_tf_vol_anchored(sp, sl, tp, lookback) =>
    float s_dens = 0.0, float t_dens = 0.0, float avg_v = 0.0
    float zone_vol_s = 0.0, float zone_vol_t = 0.0, float total_v = 0.0
    float upper_s = math.max(sp, sl), float lower_s = math.min(sp, sl)
    float upper_t = math.max(sp, tp), float lower_t = math.min(sp, tp)
    int lb = math.min(lookback, 300)
    
    int cache_key = bar_index
    if map.contains(avp_cache, cache_key)
        avg_v := map.get(avp_cache, cache_key)
    else
        if lb > 0
            for i = 0 to lb - 1
                float bar_h = high[i], float bar_l = low[i], float bar_vol = volume[i]
                total_v += bar_vol
                float bar_range = bar_h - bar_l
                if bar_range > 0
                    float intersect_s = math.max(0, math.min(bar_h, upper_s) - math.max(bar_l, lower_s))
                    zone_vol_s += bar_vol * (intersect_s / bar_range)
                    float intersect_t = math.max(0, math.min(bar_h, upper_t) - math.max(bar_l, lower_t))
                    zone_vol_t += bar_vol * (intersect_t / bar_range)
            avg_v := total_v / lb
            if total_v > 0
                s_dens := (zone_vol_s / total_v) * 100
                t_dens := (zone_vol_t / total_v) * 100
            map.put(avp_cache, cache_key, avg_v)

    [s_dens, t_dens, avg_v]

[stop_density_l, tp_density_l, avg_anchor_vol_l] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_long, sl_long, tp_long, anchor_bars))
[stop_density_s, tp_density_s, avg_anchor_vol_s] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_short, sl_short, tp_short, anchor_bars))

lower_tf_vol_arr = request.security_lower_tf(syminfo.tickerid, vol_timeframe, volume)
float current_bar_lower_vol = array.size(lower_tf_vol_arr) > 0 ? array.sum(lower_tf_vol_arr) : volume 

float rld_pct_l = avg_anchor_vol_l > 0 ? (current_bar_lower_vol / avg_anchor_vol_l) * 100 : 0
float rld_pct_s = avg_anchor_vol_s > 0 ? (current_bar_lower_vol / avg_anchor_vol_s) * 100 : 0

bool vol_cond_long  = stop_density_l >= opt_min_stop and tp_density_l <= opt_max_tp and rld_pct_l < opt_rld
bool vol_cond_short = stop_density_s >= opt_min_stop and tp_density_s <= opt_max_tp and rld_pct_s < opt_rld

bool long_trigger  = d_wpr >= 80 and close < open and not is_doji and close > d_lo
bool short_trigger = d_wpr <= 20 and close > open and not is_doji and close < d_up

bool fire_long  = weinstein_stage == 2 and w_trend == 1  and setup_strict_long  and long_trigger  and vol_cond_long  and not firewall_l and barstate.isconfirmed
bool fire_short = weinstein_stage == 4 and w_trend == -1 and setup_strict_short and short_trigger and vol_cond_short and not firewall_s and barstate.isconfirmed

// ==========================================
// --- 5. RISK RECYCLING BACKTEST EXECUTIONS ---
// ==========================================
var float entry_price = na
var float current_sl = na
var bool  tp_hit_1 = false
var int   trade_dir = 0 

// Long Einstieg
if fire_long and strategy.position_size == 0
    int qty = int(dyn_shares_l(sp_long, sl_long))
    if qty > 0
        strategy.entry("Long", strategy.long, qty=qty, stop=sp_long)
        entry_price := sp_long
        current_sl  := sl_long
        tp_hit_1    := false
        trade_dir   := 1

// Short Einstieg
if fire_short and strategy.position_size == 0
    int qty = int(dyn_shares_s(sp_short, sl_short))
    if qty > 0
        strategy.entry("Short", strategy.short, qty=qty, stop=sp_short)
        entry_price := sp_short
        current_sl  := sl_short
        tp_hit_1    := false
        trade_dir   := -1

// Management (1:1 Teilverkauf & Trailing Stop)
if strategy.position_size > 0
    if trade_dir == 1
        float target = entry_price + (entry_price - current_sl)
        if not tp_hit_1 and high >= target
            strategy.close("Long", qty_percent=50, comment="TP 1:1")
            current_sl := entry_price // BE Stop
            tp_hit_1 := true
        
        if tp_hit_1
            if close < ema21 or w_trend == -1
                strategy.close("Long", comment="Trail/Trend Break")
        
        strategy.exit("SL_Long", "Long", stop=current_sl)

    else if trade_dir == -1
        float target = entry_price - (current_sl - entry_price) // Mathematischer Offset für Short TP
        if not tp_hit_1 and low <= target
            strategy.close("Short", qty_percent=50, comment="TP 1:1")
            current_sl := entry_price // BE Stop
            tp_hit_1 := true
        
        if tp_hit_1
            if close > ema21 or w_trend == 1
                strategy.close("Short", comment="Trail/Trend Break")
        
        strategy.exit("SL_Short", "Short", stop=current_sl)
else
    trade_dir := 0

// ==========================================
// --- 6. IBKR OVERLAY & MISS-ANALYSE ---
// ==========================================
var int missed_goldens_vix = 0
if (w_trend == 1 and setup_strict_long and vol_cond_long and firewall_l)
    missed_goldens_vix += 1
if (w_trend == -1 and setup_strict_short and vol_cond_short and firewall_s)
    missed_goldens_vix += 1

string ibkr_report = "--- IBKR REALITY CHECK ---\n"
if syminfo.ticker == "LHA" or syminfo.ticker == "TEAM" or syminfo.ticker == "PYPL" or syminfo.ticker == "CSCO"
    ibkr_report += "Tick: " + syminfo.ticker + "\n"
    if syminfo.ticker == "CSCO"
        ibkr_report += "Hinweis: CSCO Long (Entry~80.10) " 
        ibkr_report += firewall_l ? "wurde durch OMEGA Mode blockiert.\n" : "wurde durch ALPHA/DELTA zugelassen.\n"

var table rep_tab = table.new(position.bottom_right, 2, 8, border_width=1)
if barstate.islast
    table.cell(rep_tab, 0, 0, "AKJ v20.5 Backtest Metriken", bgcolor=color.black, text_color=color.white)
    table.merge_cells(rep_tab, 0, 0, 1, 0)
    table.cell(rep_tab, 0, 1, "OMEGA Blocks (Opportunity Cost)", text_color=color.white, bgcolor=color.rgb(30,30,30))
    table.cell(rep_tab, 1, 1, str.tostring(missed_goldens_vix) + " Trades", text_color=color.yellow, bgcolor=color.rgb(30,30,30))
    table.cell(rep_tab, 0, 2, "Net Profit (Simulated)", text_color=color.white, bgcolor=color.rgb(30,30,30))
    table.cell(rep_tab, 1, 2, str.tostring(strategy.netprofit, "#.##") + " €", text_color=strategy.netprofit > 0 ? color.lime : color.red, bgcolor=color.rgb(30,30,30))
    table.cell(rep_tab, 0, 3, "Win Rate (Teilverkäufe 1:1)", text_color=color.white, bgcolor=color.rgb(30,30,30))
    table.cell(rep_tab, 1, 3, str.tostring(strategy.wintrades / math.max(1, strategy.closedtrades) * 100, "#.##") + "%", text_color=color.white, bgcolor=color.rgb(30,30,30))
    
    // Ausgabe der Realdaten IBKR
    table.cell(rep_tab, 0, 4, "IBKR Sync Note", text_color=color.white, bgcolor=color.blue)
    table.cell(rep_tab, 1, 4, (syminfo.ticker == "CSCO" or syminfo.ticker == "TEAM" or syminfo.ticker == "PYPL" or syminfo.ticker == "LHA") ? ibkr_report : "N/A", text_color=color.white, bgcolor=color.rgb(20,20,20))

    string debug_str = "Clear (Setup Ready)"
    if firewall_l and firewall_s
        debug_str := "Blocked: VIX OMEGA"
    else if stop_density_l < opt_min_stop and w_trend == 1
        debug_str := "Blocked (Long): Wall < 10%"
    else if stop_density_s < opt_min_stop and w_trend == -1
        debug_str := "Blocked (Short): Wall < 10%"
    else if tp_density_l > opt_max_tp and w_trend == 1
        debug_str := "Blocked (Long): TP > 8%"
    else if tp_density_s > opt_max_tp and w_trend == -1
        debug_str := "Blocked (Short): TP > 8%"
    else if rld_pct_l > opt_rld and w_trend == 1
        debug_str := "Blocked (Long): RLD Vakuum"
    else if rld_pct_s > opt_rld and w_trend == -1
        debug_str := "Blocked (Short): RLD Vakuum"
        
    table.cell(rep_tab, 0, 5, "Debug Status", text_color=color.white, bgcolor=color.rgb(40,40,40))
    table.cell(rep_tab, 1, 5, debug_str, text_color=color.orange, bgcolor=color.rgb(20,20,20))
