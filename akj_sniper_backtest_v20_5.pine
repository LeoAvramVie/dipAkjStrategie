//@version=6
strategy("AKJ 2.0 Backtest-Engine v20.5", overlay=true, initial_capital=50000, default_qty_type=strategy.cash, commission_type=strategy.commission.cash_per_order, commission_value=2.0, slippage=1, calc_on_every_tick=true)

// ==========================================
// --- 1. INPUTS ---
// ==========================================
group_rm         = "Risikomanagement"
risk_per_trade   = input.float(150.0, "Basis Risiko pro Trade (€)", group=group_rm)
limit_offset_pct = input.float(0.2, "Limit-Offset (%)", group=group_rm)
use_dyn_risk     = input.bool(true, "Asymmetrisches Risk (Alpha/Delta/Omega)", group=group_rm)

group_strat      = "MK-Strategie Parameter"
bb_len           = input.int(10, "Bollinger Länge", group=group_strat)
bb_mult          = input.float(1.0, "Bollinger Multiplikator", group=group_strat)
wpr_len          = input.int(4, "Williams %R Länge", group=group_strat)
atr_len          = input.int(14, "ATR Länge (Filter)", group=group_strat)
ema_exit         = input.int(21, "Trailing Stop EMA", group=group_strat)

group_vol_filter = "Volumen Filter (v20.5)"
vol_timeframe    = input.timeframe("240", "Volumen Timeframe (4H)", group=group_vol_filter)
backtest_flex_mode = input.bool(true, "Backtest-Modus (Lockerere Filter)", group=group_vol_filter)
min_stop_density = input.float(1.5, "Min. Stop-Versicherung (%) (FEUER)", group=group_vol_filter)
max_tp_density   = input.float(15.0, "Max. TP-Widerstand (%) (FEUER)", group=group_vol_filter)
golden_stop_density = input.float(3.0, "Min. Stop-Versicherung (%) (GOLDEN)", group=group_vol_filter)
golden_tp_density   = input.float(8.0, "Max. TP-Widerstand (%) (GOLDEN)", group=group_vol_filter)

// ==========================================
// --- ATR & Atmendes Risiko-Regime ---
// ==========================================
atr_val = ta.atr(atr_len)
vix_c = request.security("CBOE:VIX", "1D", close, lookahead=barmerge.lookahead_off)

// Risk Multiplikator (100% vs 25% vs 0%)
float risk_mult_l = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 0.25 : 0.0)
float risk_mult_s = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 1.0  : 0.0)

float active_risk_l = use_dyn_risk ? risk_per_trade * risk_mult_l : risk_per_trade
float active_risk_s = use_dyn_risk ? risk_per_trade * risk_mult_s : risk_per_trade

bool firewall_l = use_dyn_risk and risk_mult_l == 0.0
bool firewall_s = use_dyn_risk and risk_mult_s == 0.0

dyn_shares_l(float entry_p, float stop_p) =>
    float r = math.abs(entry_p - stop_p)
    r > 0 ? math.floor(active_risk_l / r) : 0

dyn_shares_s(float entry_p, float stop_p) =>
    float r = math.abs(entry_p - stop_p)
    r > 0 ? math.floor(active_risk_s / r) : 0

// ==========================================
// --- 2. TREND & WEINSTEIN STAGE ---
// ==========================================
f_bb_w_hist() => 
    basis = ta.sma(close, bb_len)
    dev = ta.stdev(close, bb_len) * bb_mult
    [close[1], basis[1] + dev[1], basis[1] - dev[1], close[2], basis[2] + dev[2], basis[2] - dev[2], ta.sma(close, 30)[1], ta.sma(close, 30)[2]]

[w_cl_1, w_up_1, w_lo_1, w_cl_2, w_up_2, w_lo_2, w_sma30_1, w_sma30_2] = request.security(syminfo.tickerid, "W", f_bb_w_hist(), lookahead=barmerge.lookahead_off)

var int w_trend = 0 
if w_cl_1 > w_up_1 and w_cl_2 > w_up_2
    w_trend := 1
else if w_cl_1 < w_lo_1 and w_cl_2 < w_lo_2
    w_trend := -1

int weinstein_stage = 0
if w_cl_1 > w_sma30_1 and w_sma30_1 > w_sma30_2
    weinstein_stage := 2
else if w_cl_1 < w_sma30_1 and w_sma30_1 < w_sma30_2
    weinstein_stage := 4

var int stage_change_bar = bar_index
if ta.change(weinstein_stage) != 0
    stage_change_bar := bar_index
int anchor_bars = math.max(1, bar_index - stage_change_bar)

// ==========================================
// --- 3. TAGES-LOGIK & TRIGGER ---
// ==========================================
[d_basis, d_up, d_lo] = ta.bb(close, bb_len, bb_mult)
atr_buffer = atr_val * 0.2

var bool setup_strict_long = false
var bool setup_strict_short = false

if close[1] > d_up[1] + atr_buffer and close[2] > d_up[2] + atr_buffer
    setup_strict_long := true
if close[1] < d_lo[1] - atr_buffer and close[2] < d_lo[2] - atr_buffer
    setup_strict_short := true

if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_long := false
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_short := false

d_wpr = math.abs(ta.wpr(wpr_len))
bool is_doji = math.abs(close - open) < (atr_val * 0.1)
float ema21 = ta.ema(close, ema_exit)

float atr_stop_dist = atr_val * 1.0 // v20.6: ATR Stop auf 1.0 reduziert

float sp_long  = high
float sl_long  = low - atr_stop_dist
float tp_long  = sp_long + (sp_long - sl_long)

float sp_short = low
float sl_short = high + atr_stop_dist
float tp_short = sp_short - (sl_short - sp_short)

// ==========================================
// ==========================================
// --- 4. VOLUMEN-STRUKTUR (Hintergrund-Radar) ---
// ==========================================

f_calc_tf_vol_anchored(sp, sl, tp, lookback) =>
    float s_dens = 0.0, float t_dens = 0.0, float avg_v = 0.0
    float zone_vol_s = 0.0, float zone_vol_t = 0.0, float total_v = 0.0
    float upper_s = math.max(sp, sl), float lower_s = math.min(sp, sl)
    float upper_t = math.max(sp, tp), float lower_t = math.min(sp, tp)
    int lb = math.min(lookback, 300)
    
    if lb > 0
        for i = 0 to lb - 1
            float bar_h = high[i], float bar_l = low[i], float bar_vol = volume[i]
            total_v += bar_vol
            float bar_range = bar_h - bar_l
            if bar_range > 0
                float intersect_s = math.max(0, math.min(bar_h, upper_s) - math.max(bar_l, lower_s))
                zone_vol_s += bar_vol * (intersect_s / bar_range)
                float intersect_t = math.max(0, math.min(bar_h, upper_t) - math.max(bar_l, lower_t))
                zone_vol_t += bar_vol * (intersect_t / bar_range)
        avg_v := total_v / lb
        if total_v > 0
            s_dens := (zone_vol_s / total_v) * 100
            t_dens := (zone_vol_t / total_v) * 100

    [s_dens, t_dens, avg_v]

[stop_density_l, tp_density_l, avg_anchor_vol_l] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_long, sl_long, tp_long, anchor_bars))
[stop_density_s, tp_density_s, avg_anchor_vol_s] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_short, sl_short, tp_short, anchor_bars))

lower_tf_vol_arr = request.security_lower_tf(syminfo.tickerid, vol_timeframe, volume)
float current_bar_lower_vol = array.size(lower_tf_vol_arr) > 0 ? array.sum(lower_tf_vol_arr) : volume 

float rld_pct_l = avg_anchor_vol_l > 0 ? (current_bar_lower_vol / avg_anchor_vol_l) * 100 : 0
float rld_pct_s = avg_anchor_vol_s > 0 ? (current_bar_lower_vol / avg_anchor_vol_s) * 100 : 0

// Vakuum-Condition basiert nun auf reiner TP-Weitsicht, RLD entkoppelt
bool vol_feuer_l  = stop_density_l >= min_stop_density and tp_density_l <= max_tp_density
bool vol_feuer_s  = stop_density_s >= min_stop_density and tp_density_s <= max_tp_density
bool vol_golden_l = stop_density_l >= golden_stop_density and tp_density_l <= golden_tp_density
bool vol_golden_s = stop_density_s >= golden_stop_density and tp_density_s <= golden_tp_density

bool long_trigger_70  = d_wpr >= 70 and close < open and not is_doji and close > d_lo
bool long_trigger_80  = d_wpr >= 80 and close < open and not is_doji and close > d_lo
bool short_trigger_30 = d_wpr <= 30 and close > open and not is_doji and close < d_up
bool short_trigger_20 = d_wpr <= 20 and close > open and not is_doji and close < d_up

// ==========================================
// --- 5. FUNNEL & STATUS-AUDIT SYSTEM (v20.5) ---
// ==========================================
type VirtualTrade
    int   t_class // 1 = Lauern, 2 = Feuer Frei, 3 = Golden
    int   dir     // 1 = Long, -1 = Short
    float ep
    float sl
    float tp
    float r_dist
    bool  tp1_hit

var virtual_trades = array.new<VirtualTrade>()

// Stat-Counter (Closed Trades: Win vs Loss)
var int w_lauern = 0
var int w_feuer = 0
var int w_golden = 0

var int l_lauern = 0
var int l_feuer = 0
var int l_golden = 0

var float p_lauern = 0.0
var float p_feuer = 0.0
var float p_golden = 0.0

var int total_missed_omega = 0

// Definition der Audit-Level (v20.6 WPR Cascade Sensitivity)
bool is_radar_l = high >= d_up + (atr_val * 0.2)
bool radar_state_l = weinstein_stage == 2 and (is_radar_l or setup_strict_long)
bool base_lauern_l = radar_state_l and long_trigger_70 and barstate.isconfirmed // 70er Trigger Kaskade
bool raw_feuer_l   = radar_state_l and setup_strict_long and long_trigger_80 and barstate.isconfirmed // 80er Trigger
bool base_feuer_l  = raw_feuer_l and vol_feuer_l 
bool base_golden_l = raw_feuer_l and vol_golden_l 

bool is_radar_s = low <= d_lo - (atr_val * 0.2)
bool radar_state_s = weinstein_stage == 4 and (is_radar_s or setup_strict_short)
bool base_lauern_s = radar_state_s and short_trigger_30 and barstate.isconfirmed
bool raw_feuer_s   = radar_state_s and setup_strict_short and short_trigger_20 and barstate.isconfirmed
bool base_feuer_s  = raw_feuer_s and vol_feuer_s
bool base_golden_s = raw_feuer_s and vol_golden_s

// Evaluierung offener virtueller Trades
if array.size(virtual_trades) > 0
    for i = array.size(virtual_trades) - 1 to 0
        VirtualTrade vt = array.get(virtual_trades, i)
        
        bool sl_hit = false
        bool tp_hit = false
        bool runner_exit = false
        
        if vt.dir == 1
            if low <= vt.sl
                sl_hit := true
            if not vt.tp1_hit and high >= vt.tp
                tp_hit := true
            if vt.tp1_hit and (close < ema21 or w_trend == -1) // Runner Exit
                runner_exit := true
        else
            if high >= vt.sl
                sl_hit := true
            if not vt.tp1_hit and low <= vt.tp
                tp_hit := true
            if vt.tp1_hit and (close > ema21 or w_trend == 1) // Runner Exit
                runner_exit := true
                
        // Pessimistischer Ansatz
        if sl_hit and tp_hit
            tp_hit := false
            
        if not vt.tp1_hit
            // Erster Teil: SL vs TP1
            if sl_hit
                if vt.t_class == 1
                    l_lauern += 1
                    p_lauern -= 1.0
                else if vt.t_class == 2
                    l_feuer += 1
                    p_feuer -= 1.0
                else
                    l_golden += 1
                    p_golden -= 1.0
                array.remove(virtual_trades, i)
            else if tp_hit
                // 1:1 erreicht! 50% TP, Rest auf Break-Even
                if vt.t_class == 1
                    w_lauern += 1
                else if vt.t_class == 2
                    w_feuer += 1
                else
                    w_golden += 1
                
                vt.tp1_hit := true
                vt.sl := vt.ep
        else
            // Zweiter Teil: Runner Trailing Start
            if sl_hit or runner_exit
                float exit_r = 0.0
                if not sl_hit
                    float act_exit_p = close // Exit am aktuellen Kerzenschluss nach Crossing
                    exit_r := vt.dir == 1 ? (act_exit_p - vt.ep) / vt.r_dist : (vt.ep - act_exit_p) / vt.r_dist
                
                // Gesamtes R = 50% initial (1.0 R) + 50% runner (exit_r)
                float total_r = (0.5 * 1.0) + (0.5 * exit_r)
                
                if vt.t_class == 1
                    p_lauern += total_r
                else if vt.t_class == 2
                    p_feuer += total_r
                else
                    p_golden += total_r
                    
                array.remove(virtual_trades, i)

// Hilfsfunktion: Prüft, ob ein virtueller Trade mit gleicher Klasse & Richtung schon aktiv ist (Lock-Check)
f_is_active(int t_class, int dir) =>
    bool active = false
    if array.size(virtual_trades) > 0
        for i = 0 to array.size(virtual_trades) - 1
            VirtualTrade vt = array.get(virtual_trades, i)
            if vt.t_class == t_class and vt.dir == dir
                active := true
                break
    active

// Event-Zähler (Nur ansteuern, wenn Zustand NEU oder nach Lock-Freigabe wieder möglich ist)
bool evt_lauern_l = base_lauern_l and not base_lauern_l[1]
bool evt_feuer_l  = base_feuer_l  and not base_feuer_l[1]
bool evt_golden_l = base_golden_l and not base_golden_l[1]

bool evt_lauern_s = base_lauern_s and not base_lauern_s[1]
bool evt_feuer_s  = base_feuer_s  and not base_feuer_s[1]
bool evt_golden_s = base_golden_s and not base_golden_s[1]

// Neue Setups ins Audit einspeisen (LONG Event-Based)
if evt_lauern_l and not firewall_l and not f_is_active(1, 1)
    array.push(virtual_trades, VirtualTrade.new(1, 1, sp_long, sl_long, tp_long, sp_long - sl_long, false))
if evt_feuer_l and not firewall_l and not f_is_active(2, 1)
    array.push(virtual_trades, VirtualTrade.new(2, 1, sp_long, sl_long, tp_long, sp_long - sl_long, false))
if evt_golden_l
    if firewall_l
        total_missed_omega += 1
    else if not f_is_active(3, 1)
        array.push(virtual_trades, VirtualTrade.new(3, 1, sp_long, sl_long, tp_long, sp_long - sl_long, false))

// Neue Setups ins Audit einspeisen (SHORT Event-Based)
if evt_lauern_s and not firewall_s and not f_is_active(1, -1)
    array.push(virtual_trades, VirtualTrade.new(1, -1, sp_short, sl_short, tp_short, sl_short - sp_short, false))
if evt_feuer_s and not firewall_s and not f_is_active(2, -1)
    array.push(virtual_trades, VirtualTrade.new(2, -1, sp_short, sl_short, tp_short, sl_short - sp_short, false))
if evt_golden_s
    if firewall_s
        total_missed_omega += 1
    else if not f_is_active(3, -1)
        array.push(virtual_trades, VirtualTrade.new(3, -1, sp_short, sl_short, tp_short, sl_short - sp_short, false))

// ==========================================
// --- 6. AUDIT-COCKPIT UI ---
// ==========================================
var table audit_cockpit = table.new(position.top_center, 4, 6, border_width=1, border_color=color.rgb(40,40,40))

if barstate.islast
    int c_lauern = l_lauern + w_lauern
    int c_feuer  = l_feuer + w_feuer
    int c_golden = l_golden + w_golden

    float wr_lauern = c_lauern > 0 ? (w_lauern / c_lauern) * 100 : 0.0
    float wr_feuer  = c_feuer > 0 ? (w_feuer / c_feuer) * 100 : 0.0
    float wr_golden = c_golden > 0 ? (w_golden / c_golden) * 100 : 0.0

    // Profit Berechnung mit Runner-Recycling
    float r_lauern_avg = c_lauern > 0 ? p_lauern / c_lauern : 0.0
    float r_feuer_avg  = c_feuer > 0 ? p_feuer / c_feuer : 0.0
    float r_golden_avg = c_golden > 0 ? p_golden / c_golden : 0.0

    float eur_lauern = r_lauern_avg * risk_per_trade
    float eur_feuer = r_feuer_avg * risk_per_trade
    float eur_golden = r_golden_avg * risk_per_trade

    color bg_eur_l = eur_lauern > 0 ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)
    color bg_eur_f = eur_feuer > 0 ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)
    color bg_eur_g = eur_golden > 0 ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)

    table.cell(audit_cockpit, 0, 0, "AKJ v20.6 SNR-State-Audit", bgcolor=color.black, text_color=color.white, text_size=size.large)
    table.merge_cells(audit_cockpit, 0, 0, 3, 0)
    
    // Star-Ticker Label Logic
    string star_l = wr_lauern >= 50 ? " ⭐" : ""
    string star_f = wr_feuer >= 50 ? " ⭐" : ""
    string star_g = wr_golden >= 50 ? " ⭐" : ""

    // Header
    table.cell(audit_cockpit, 0, 1, "Status-Typ", bgcolor=color.rgb(30,30,30), text_color=color.gray)
    table.cell(audit_cockpit, 1, 1, "Signal-Events", bgcolor=color.rgb(30,30,30), text_color=color.gray)
    table.cell(audit_cockpit, 2, 1, "Win % (1:1 TP)", bgcolor=color.rgb(30,30,30), text_color=color.gray)
    table.cell(audit_cockpit, 3, 1, "Erwartungswert (€)", bgcolor=color.rgb(30,30,30), text_color=color.gray)

    // Lauern
    table.cell(audit_cockpit, 0, 2, "LAUERN (Radar)" + star_l, bgcolor=color.rgb(20,20,20), text_color=color.yellow)
    table.cell(audit_cockpit, 1, 2, str.tostring(c_lauern), bgcolor=color.rgb(20,20,20), text_color=color.silver)
    table.cell(audit_cockpit, 2, 2, str.tostring(wr_lauern, "#.#") + "%", bgcolor=wr_lauern >= 50 ? color.rgb(10,50,10) : color.rgb(40,10,10), text_color=color.white)
    table.cell(audit_cockpit, 3, 2, (eur_lauern > 0 ? "+" : "") + str.tostring(eur_lauern, "#.##") + " €", bgcolor=bg_eur_l, text_color=color.white)

    // Feuer Frei
    table.cell(audit_cockpit, 0, 3, "FEUER FREI" + star_f, bgcolor=color.rgb(20,20,20), text_color=color.blue)
    table.cell(audit_cockpit, 1, 3, str.tostring(c_feuer), bgcolor=color.rgb(20,20,20), text_color=color.silver)
    table.cell(audit_cockpit, 2, 3, str.tostring(wr_feuer, "#.#") + "%", bgcolor=wr_feuer >= 50 ? color.rgb(10,50,10) : color.rgb(40,10,10), text_color=color.white)
    table.cell(audit_cockpit, 3, 3, (eur_feuer > 0 ? "+" : "") + str.tostring(eur_feuer, "#.##") + " €", bgcolor=bg_eur_f, text_color=color.white)

    // Golden Setup
    table.cell(audit_cockpit, 0, 4, "GOLDEN SETUP" + star_g, bgcolor=color.rgb(20,20,20), text_color=color.lime)
    table.cell(audit_cockpit, 1, 4, str.tostring(c_golden), bgcolor=color.rgb(20,20,20), text_color=color.white)
    table.cell(audit_cockpit, 2, 4, str.tostring(wr_golden, "#.#") + "%", bgcolor=wr_golden >= 50 ? color.rgb(10,60,10) : color.rgb(60,10,10), text_color=color.white)
    table.cell(audit_cockpit, 3, 4, (eur_golden > 0 ? "+" : "") + str.tostring(eur_golden, "#.##") + " €", bgcolor=bg_eur_g, text_color=color.white)

    // Metrik Omega
    table.cell(audit_cockpit, 0, 5, "VIX Efficiency (Blocked by OMEGA): " + str.tostring(total_missed_omega), bgcolor=color.rgb(10,10,10), text_color=color.orange, text_size=size.small)
    table.merge_cells(audit_cockpit, 0, 5, 3, 5)

// ==========================================
// --- 7. STRATEGY EXEKUTION (Real Backtest) ---
// ==========================================
// PFLICHT: Ein Strategy-Script benötigt entry()-Calls zum Kompilieren. Wir feuern hier das Golden Setup ab!
if evt_golden_l and not firewall_l and strategy.position_size == 0
    strategy.entry("Long", strategy.long, qty=dyn_shares_l(sp_long, sl_long), stop=sp_long)
    strategy.exit("TP1_L", "Long", qty_percent=50, stop=sl_long, limit=tp_long)

if strategy.position_size > 0
    float be_stop = strategy.opentrades.entry_price(0)
    if close < ema21 or w_trend == -1
        strategy.close("Long", comment="Runner Out")
    else
        strategy.exit("Trail_L", "Long", stop=math.max(sl_long, be_stop))

if evt_golden_s and not firewall_s and strategy.position_size == 0
    strategy.entry("Short", strategy.short, qty=dyn_shares_s(sp_short, sl_short), stop=sp_short)
    strategy.exit("TP1_S", "Short", qty_percent=50, stop=sl_short, limit=tp_short)

if strategy.position_size < 0
    float be_stop = strategy.opentrades.entry_price(0)
    if close > ema21 or w_trend == 1
        strategy.close("Short", comment="Runner Out")
    else
        strategy.exit("Trail_S", "Short", stop=math.min(sl_short, be_stop))
