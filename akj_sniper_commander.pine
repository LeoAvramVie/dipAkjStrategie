//@version=6
indicator("AKJ 2.0 Sniper-Commander v20.5", overlay=true, max_labels_count=500)

// ==========================================
// --- 1. INPUTS ---
// ==========================================
group_rm         = "Risikomanagement"
risk_per_trade   = input.float(150.0, "Basis Risiko pro Trade (€)", group=group_rm)
limit_offset_pct = input.float(0.2, "Limit-Offset (%)", group=group_rm)
puffer_ticks     = input.int(2, "Puffer in Ticks", group=group_rm)
use_dyn_risk     = input.bool(true, "Asymmetrisches Risk (Alpha/Delta/Omega)", group=group_rm)

group_strat      = "MK-Strategie Parameter"
bb_len           = input.int(10, "Bollinger Länge", group=group_strat)
bb_mult          = input.float(1.0, "Bollinger Multiplikator", group=group_strat)
wpr_len          = input.int(4, "Williams %R Länge", group=group_strat)
atr_len          = input.int(14, "ATR Länge (Filter)", group=group_strat)

group_vol_filter = "Volumen Filter (v20.5)"
vol_timeframe    = input.timeframe("240", "Volumen Timeframe (4H)", group=group_vol_filter)
min_stop_density = input.float(10.0, "Min. Stop-Versicherung (%)", group=group_vol_filter)
max_tp_density   = input.float(8.0, "Max. TP-Widerstand (%)", group=group_vol_filter)
rld_limit        = input.float(20.0, "RLD Vakuum Limit (%)", group=group_vol_filter)

group_rs         = "Sektor & Relative Stärke (v20.5)"
use_auto_etf     = input.bool(true, "Auto-Detect Sektor", group=group_rs)
user_etf         = input.symbol("SPY", "Manueller Sektor-ETF", group=group_rs)

// ==========================================
// --- ATR & Atmendes Risiko-Regime (Asymmetrisch) ---
// ==========================================
atr_val = ta.atr(atr_len)
vix_c = request.security("CBOE:VIX", "1D", close, lookahead=barmerge.lookahead_off)

// Asymmetrische Risk Multiplier Logik
float risk_mult_l = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 0.25 : 0.0)
float risk_mult_s = vix_c < 25.0 ? 1.0 : (vix_c <= 35.0 ? 1.0  : 0.0)

float active_risk_l = use_dyn_risk ? risk_per_trade * risk_mult_l : risk_per_trade
float active_risk_s = use_dyn_risk ? risk_per_trade * risk_mult_s : risk_per_trade

bool firewall_l = use_dyn_risk and risk_mult_l == 0.0
bool firewall_s = use_dyn_risk and risk_mult_s == 0.0

string risk_mode_txt = vix_c < 25.0 ? "ALPHA (Full)" : (vix_c <= 35.0 ? "DELTA (Short-Bias)" : "OMEGA (Lock)")
color  risk_mode_bg  = vix_c < 25.0 ? color.rgb(10, 60, 10) : (vix_c <= 35.0 ? color.rgb(200, 100, 0) : color.rgb(100, 10, 10))
string rm_tooltip    = "ALPHA: Volles Risiko. DELTA: Longs gebremst (25% R), Shorts aktiv (100% R). OMEGA: Handelsstopp wegen Extrem-Volatilität."

string mode_prefix = vix_c < 25.0 ? "ALPHA Mode" : (vix_c <= 35.0 ? "DELTA Mode" : "OMEGA Mode")

d_wpr = math.abs(ta.wpr(wpr_len))

// ==========================================
// --- 2. WOCHEN-DATA (Sticky & Strict) ---
// ==========================================
f_bb_w_hist() => 
    basis = ta.sma(close, bb_len)
    dev = ta.stdev(close, bb_len) * bb_mult
    [close[1], basis[1] + dev[1], basis[1] - dev[1], close[2], basis[2] + dev[2], basis[2] - dev[2], ta.sma(close, 30)[1], ta.sma(close, 30)[2]]

[w_cl_1, w_up_1, w_lo_1, w_cl_2, w_up_2, w_lo_2, w_sma30_1, w_sma30_2] = request.security(syminfo.tickerid, "W", f_bb_w_hist(), lookahead=barmerge.lookahead_off)

var int w_trend = 0 
if w_cl_1 > w_up_1 and w_cl_2 > w_up_2
    w_trend := 1
else if w_cl_1 < w_lo_1 and w_cl_2 < w_lo_2
    w_trend := -1

int weinstein_stage = 0
if w_cl_1 > w_sma30_1 and w_sma30_1 > w_sma30_2
    weinstein_stage := 2
else if w_cl_1 < w_sma30_1 and w_sma30_1 < w_sma30_2
    weinstein_stage := 4

string ws_txt = weinstein_stage == 2 ? "STAGE 2 OK Long ✅" : weinstein_stage == 4 ? "STAGE 4 OK Short ✅" : "SEITWÄRTS"
color  ws_bg  = weinstein_stage == 2 ? color.blue : weinstein_stage == 4 ? color.red : color.rgb(30, 30, 30)

// --- Anchor Logic (v20.5) ---
var int stage_change_bar = bar_index
if ta.change(weinstein_stage) != 0
    stage_change_bar := bar_index

int anchor_bars = math.max(1, bar_index - stage_change_bar)
if anchor_bars > 300
    anchor_bars := 300 // CPU Saver

// ==========================================
// --- 3. TAGES-LOGIK (Sticky Trend Hysterese v20.5) ---
// ==========================================
[d_basis, d_up, d_lo] = ta.bb(close, bb_len, bb_mult)
atr_buffer = atr_val * 0.2

var bool setup_strict_long  = false
var bool setup_strict_short = false

if close[1] > d_up[1] + atr_buffer and close[2] > d_up[2] + atr_buffer
    setup_strict_long := true
if close[1] < d_lo[1] - atr_buffer and close[2] < d_lo[2] - atr_buffer
    setup_strict_short := true

if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_long := false
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_short := false

bool is_in_radar_long  = close[1] > d_up[1] or setup_strict_long
bool is_in_radar_short = close[1] < d_lo[1] or setup_strict_short

// ==========================================
// --- 4. PREIS-BERECHNUNG ---
// ==========================================
puffer = syminfo.mintick * puffer_ticks

float sp_long  = high + puffer
float sl_long  = low - puffer
float r_l = math.abs(sp_long - sl_long)
int shares_l = r_l > 0 ? math.floor(active_risk_l / r_l) : 0

float sp_short = low - puffer
float sl_short = high + puffer
float r_s = math.abs(sp_short - sl_short)
int shares_s = r_s > 0 ? math.floor(active_risk_s / r_s) : 0

float sp_price = w_trend == -1 ? sp_short : sp_long
float sl_price = w_trend == -1 ? sl_short : sl_long
int   shares   = w_trend == -1 ? shares_s : shares_l
float risk_val = w_trend == -1 ? r_s : r_l
float lp_price = w_trend == -1 ? sp_price * (1 - limit_offset_pct / 100) : sp_price * (1 + limit_offset_pct / 100)
float tp_price = w_trend == -1 ? sp_price - risk_val : sp_price + risk_val
float active_risk_display = w_trend == -1 ? active_risk_s : active_risk_l

// ==========================================
// --- 5. VOLUMEN-STRUKTUR ---
// ==========================================
f_calc_tf_vol_anchored(sp, sl, tp, do_calc, lookback) =>
    float s_dens = 0.0
    float t_dens = 0.0
    float avg_v = 0.0
    if do_calc
        float zone_vol_s = 0.0
        float zone_vol_t = 0.0
        float total_v    = 0.0
        float upper_s = math.max(sp, sl), float lower_s = math.min(sp, sl)
        float upper_t = math.max(sp, tp), float lower_t = math.min(sp, tp)
        int lb = math.min(lookback, 300)
        if lb > 0
            for i = 0 to lb - 1
                float bar_h = high[i], float bar_l = low[i], float bar_vol = volume[i]
                total_v += bar_vol
                float bar_range = bar_h - bar_l
                if bar_range > 0
                    float intersect_s = math.max(0, math.min(bar_h, upper_s) - math.max(bar_l, lower_s))
                    zone_vol_s += bar_vol * (intersect_s / bar_range)
                    float intersect_t = math.max(0, math.min(bar_h, upper_t) - math.max(bar_l, lower_t))
                    zone_vol_t += bar_vol * (intersect_t / bar_range)
            avg_v := total_v / lb
            if total_v > 0
                s_dens := (zone_vol_s / total_v) * 100
                t_dens := (zone_vol_t / total_v) * 100
    [s_dens, t_dens, avg_v]

bool needs_vol_calc = is_in_radar_long or is_in_radar_short or barstate.islast
[stop_density, tp_density, avg_anchor_vol] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_price, sl_price, tp_price, needs_vol_calc, anchor_bars))

lower_tf_vol_arr = request.security_lower_tf(syminfo.tickerid, vol_timeframe, volume)
float current_bar_lower_vol = 0.0
if array.size(lower_tf_vol_arr) > 0
    current_bar_lower_vol := array.sum(lower_tf_vol_arr)

float rld_pct = avg_anchor_vol > 0 ? (current_bar_lower_vol / avg_anchor_vol) * 100 : 0
bool rld_valid = rld_pct < rld_limit
string vacuum_qual = rld_valid ? "High" : "Low (" + str.tostring(rld_pct, "#.#") + "%)"

// ==========================================
// --- 6. SIGNAL-IDENTIFIKATION ---
// ==========================================
bool is_doji = math.abs(close - open) < (atr_val * 0.1)

// Long-Signal
bool long_trigger = d_wpr >= 80 and close < open and not is_doji and close > d_lo
bool is_sniper_long  = w_trend == 1  and setup_strict_long  and long_trigger

// Short-Signal
bool short_trigger = d_wpr <= 20 and close > open and not is_doji and close < d_up
bool is_sniper_short = w_trend == -1 and setup_strict_short and short_trigger

// Golden Setup 
bool rld_approved_tp = tp_density <= max_tp_density and rld_valid
bool vol_condition  = stop_density >= min_stop_density and rld_approved_tp

// Firewall blockt je nach Regime
bool is_golden_long  = is_sniper_long  and vol_condition and not firewall_l
bool is_golden_short = is_sniper_short and vol_condition and not firewall_s

bool is_lauern_long   = w_trend == 1  and is_in_radar_long  and d_wpr >= 70 and not is_sniper_long and not firewall_l
bool is_lauern_short  = w_trend == -1 and is_in_radar_short and d_wpr <= 30 and not is_sniper_short and not firewall_s

// ==========================================
// --- 7. SEKTOR & RELATIVE STÄRKE ---
// ==========================================
f_get_auto_sector() =>
    string etf   = "SPY"
    string sec   = syminfo.sector
    string ind   = syminfo.industry
    string sname = sec != "" ? sec : "S&P 500 Index"
    
    if use_auto_etf
        if ind == "Aerospace & Defense"
            etf := "ITA"
            sname := "Rüstung & Aero"
        else if ind == "Semiconductors"
            etf := "SMH"
            sname := "Halbleiter"
        else if sec == "Electronic Technology" or sec == "Technology Services"
            etf := "XLK"
        else if sec == "Energy Minerals"
            etf := "XLE"
        else if sec == "Finance" or sec == "Commercial Services"
            etf := "XLF"
        else if sec == "Health Technology" or sec == "Health Services"
            etf := "XLV"
        else if sec == "Producer Manufacturing" or sec == "Industrial Services"
            etf := "XLI"
        else if sec == "Consumer Durables" or sec == "Retail Trade" or sec == "Consumer Services"
            etf := "XLY"
        else if sec == "Consumer Non-Durables" or sec == "Process Industries"
            etf := "XLP"
        else if sec == "Non-Energy Minerals"
            etf := "XLB"
        else if sec == "Communications"
            etf := "XLC"
        else if sec == "Utilities"
            etf := "XLU"
        else if sec == "Real Estate"
            etf := "XLRE"
    
    if not use_auto_etf or etf == "SPY"
        etf := user_etf
        sname := user_etf == "SPY" ? "S&P 500" : (sec != "" ? sec : "Index/ETF")
        
    [etf, sname]

[sector_ticker, sector_name] = f_get_auto_sector()
[etf_c, etf_sma, etf_c20] = request.security(sector_ticker, "1D", [close, ta.sma(close, 10), close[20]], lookahead=barmerge.lookahead_off)

bool sector_long = etf_c > etf_sma
string sec_txt = sector_name + " (" + sector_ticker + ")"
color sec_bg = sector_long ? color.blue : color.red

float stock_perf = close[20] != 0 ? ((close - close[20]) / close[20]) * 100 : 0.0
float etf_perf   = etf_c20 != 0 ? ((etf_c - etf_c20) / etf_c20) * 100 : 0.0
float perf_diff  = stock_perf - etf_perf

string rs_txt = perf_diff > 2.0 ? "STARK" : perf_diff < -2.0 ? "SCHWACH" : "MITTEL"
color  rs_bg  = perf_diff > 2.0 ? color.blue : perf_diff < -2.0 ? color.red : color.rgb(30, 30, 30)

// ==========================================
// --- 8. UI LOGIK & FARBEN ---
// ==========================================
color color_himmelblau = color.rgb(0, 191, 255)
color color_hellrot = color.rgb(240, 128, 128)
color color_gold = color.rgb(13, 255, 0)

bool is_any_action = is_sniper_long or is_sniper_short or is_golden_long or is_golden_short
color action_color = (is_sniper_long or is_golden_long) ? color.blue : color.red

// Trend UI Strings
string wt_txt = w_trend == 1 ? "BULLISCH ⬆️ (Sticky)" : w_trend == -1 ? "BÄRISCH ⬇️ (Sticky)" : "NEUTRAL ↔️"
color  wt_bg  = w_trend == 1 ? color.blue : w_trend == -1 ? color.red : color.rgb(30, 30, 30)

string dt_txt = setup_strict_long ? "LONG (Scharf)" : setup_strict_short ? "SHORT (Scharf)" : is_in_radar_long ? "LONG (Radar)" : is_in_radar_short ? "SHORT (Radar)" : "NEUTRAL"
color  dt_bg  = setup_strict_long ? color.blue : setup_strict_short ? color.red : (is_in_radar_long or is_in_radar_short) ? color.yellow : color.rgb(30, 30, 30)

// Candles
string c_txt = ""
color  c_bg  = color.rgb(30, 30, 30)
if w_trend == 1
    c_txt := (close < open and not is_doji) ? "OK ✅" : "WAIT ⏳"
    c_bg  := (close < open and not is_doji) ? color.blue : color.rgb(30, 30, 30)
else if w_trend == -1
    c_txt := (close > open and not is_doji) ? "OK ✅" : "WAIT ⏳"
    c_bg  := (close > open and not is_doji) ? color.red : color.rgb(30, 30, 30)

if is_any_action
    ws_bg := action_color, c_bg := action_color, wt_bg := action_color, dt_bg := action_color

// ==========================================
// --- 9. COCKPIT UI ---
// ==========================================
var table cp = table.new(position.top_right, 2, 23, border_width=1, border_color=color.new(color.white, 80), frame_width=1, frame_color=color.new(color.white, 80))
f_p(val) => na(val) ? "-" : str.tostring(val, "#.##")

if barstate.islast
    string tac_txt = "STAY"
    color tac_bg = color.rgb(20, 20, 20)
    
    bool is_omega = vix_c > 35.0
    bool is_delta = vix_c > 25.0 and vix_c <= 35.0

    if is_omega
        tac_txt := "!!! FIREWALL LOCK !!!"
        tac_bg  := color.red
    else if is_delta and (is_golden_long or is_sniper_long)
        tac_txt := "LAUERN LONG (VIX HIGH)"
        tac_bg  := color.yellow
    else if is_delta and (is_golden_short or is_sniper_short)
        tac_txt := "!!! FEUER FREI SHORT !!!"
        tac_bg  := color.red
    else if is_golden_long
        tac_txt := "!! GOLDEN LONG !!"
        tac_bg  := color_gold
    else if is_golden_short
        tac_txt := "!! GOLDEN SHORT !!"
        tac_bg  := color_gold
    else if is_sniper_long
        tac_txt := "! FEUER FREI LONG !"
        tac_bg  := color.blue
    else if is_sniper_short
        tac_txt := "! FEUER FREI SHORT !"
        tac_bg  := color.red
    else if is_lauern_long
        tac_txt := "LAUERN LONG"
        tac_bg  := color.yellow
    else if is_lauern_short
        tac_txt := "LAUERN SHORT"
        tac_bg  := color.yellow
    
    table.cell(cp, 0, 0, " STATUS ", bgcolor=color.black, text_color=color.white, text_size=size.normal)
    table.cell(cp, 1, 0, tac_txt, bgcolor=tac_bg, text_color=(tac_bg == color.yellow or tac_bg == color_gold) ? color.black : color.white, text_size=size.normal)

    table.cell(cp, 0, 1, "--- MARKT-KONTEXT ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=size.small, text_halign=text.align_center)
    table.merge_cells(cp, 0, 1, 1, 1)
    
    table.cell(cp, 0, 2, "🌍 Sektor", bgcolor=color.rgb(40, 40, 40), text_color=color.silver)
    table.cell(cp, 1, 2, sec_txt, bgcolor=sec_bg, text_color=color.white)

    table.cell(cp, 0, 3, "💪 Rel. Stärke", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Vergleicht die Performance der Aktie mit ihrem Sektor über 20 Tage. STARK bedeutet Outperformance und erhöht die Wahrscheinlichkeit für einen erfolgreichen Trade.")
    table.cell(cp, 1, 3, rs_txt, bgcolor=rs_bg, text_color=color.white)

    table.cell(cp, 0, 4, "📈 Weinstein Stage", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Strategische Marktphase nach Stan Weinstein. Stage 2 = Institutionelle Akkumulation (Long), Stage 4 = Institutionelle Distribution (Short).")
    table.cell(cp, 1, 4, ws_txt, bgcolor=ws_bg, text_color=color.white)

    table.cell(cp, 0, 5, "--- TREND-ANALYSE (v20.5) ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=size.small, text_halign=text.align_center)
    table.merge_cells(cp, 0, 5, 1, 5)

    table.cell(cp, 0, 6, "📅 Wochentrend", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Taktische Richtung auf Wochenbasis (Sticky). Erfordert 2 Schlusskurse außerhalb der Bollinger Bänder (10/1). Bleibt aktiv, bis die Gegenseite 2 Kerzen erzwingt.")
    table.cell(cp, 1, 6, wt_txt, bgcolor=wt_bg, text_color=color.white)

    table.cell(cp, 0, 7, "☀️ Tagestrend", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Kurzfristiges Timing-Radar. Nutzt einen dynamischen ATR-Puffer (Hysterese v20.5), um Fehlsignale in volatilen Phasen (VIX > 25) zu filtern.")
    table.cell(cp, 1, 7, dt_txt, bgcolor=dt_bg, text_color=(dt_bg == color.yellow) ? color.black : color.white)

    table.cell(cp, 0, 8, "--- SNIPER METRIKEN ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=size.small, text_halign=text.align_center)
    table.merge_cells(cp, 0, 8, 1, 8)

    table.cell(cp, 0, 9, "📊 Risk-O-Meter (1R)", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Dynamische Positionsgröße (1R). Passt das Risiko basierend auf der Marktangst (VIX) und der Aktien-Volatilität automatisch an.")
    table.cell(cp, 1, 9, str.tostring(active_risk_display, "#.##") + " €", bgcolor=color.rgb(30, 30, 30), text_color=color.white)

    table.cell(cp, 0, 10, "🛡️ Risk-Mode (Adaptiv)", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip=rm_tooltip)
    table.cell(cp, 1, 10, risk_mode_txt, bgcolor=risk_mode_bg, text_color=color.white)

    table.cell(cp, 0, 11, "⚓ Anchor-Info", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Startpunkt des Anchored Volume Profile (AVP). Misst das Volumen exakt ab dem letzten Weinstein-Phasenwechsel oder Pivot-Punkt.")
    table.cell(cp, 1, 11, str.tostring(anchor_bars) + " Bars ago", bgcolor=color.rgb(30, 30, 30), text_color=color.white)

    table.cell(cp, 0, 12, "📐 Vacuum Quality", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Prüft die Liquiditätsdichte (RLD). High Quality bedeutet, dass der Preis kaum auf Widerstand stoßen wird (Vakuum).")
    table.cell(cp, 1, 12, vacuum_qual, bgcolor=rld_valid ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10), text_color=color.white)

    table.cell(cp, 0, 13, "--- SIGNAL-VALIDIERUNG ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=size.small, text_halign=text.align_center)
    table.merge_cells(cp, 0, 13, 1, 13)

    table.cell(cp, 0, 14, "🕯️ Kerzenregel", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Prüft die Preis-Aktion (Scharf-Kerze) inkl. ATR-basiertem Doji-Filter. OK bedeutet: Die Käufer/Verkäufer haben die Kontrolle übernommen.")
    table.cell(cp, 1, 14, c_txt, bgcolor=c_bg, text_color=color.white)

    color s_v_bg = stop_density >= min_stop_density ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)
    table.cell(cp, 0, 15, "🛡️ Stopversicherung", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Die Volumen-Mauer (🛡️) an deinem Stopp-Level. Gemessen ab dem Ankerpunkt (v20.5). Zielwert: >10% zur Absicherung der Position.")
    table.cell(cp, 1, 15, str.tostring(stop_density, "#.#") + "%", bgcolor=s_v_bg, text_color=color.white)
    
    color t_v_bg = rld_approved_tp ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)
    table.cell(cp, 0, 16, "🚧 TP Widerstand", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, tooltip="Das Volumen-Hindernis (🚧) bis zum Ziel. Gemessen per RLD-Verfahren (v20.5). Zielwert: <8% für einen freien Lauf (Vakuum) zum Take-Profit.")
    table.cell(cp, 1, 16, str.tostring(tp_density, "#.#") + "%", bgcolor=t_v_bg, text_color=color.white)

    table.cell(cp, 0, 17, "--- ORDER-MATRIX ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=size.small, text_halign=text.align_center)
    table.merge_cells(cp, 0, 17, 1, 17)

    table.cell(cp, 0, 18, "🎯 Stoppreis (SP)", bgcolor=color.rgb(50, 50, 50), text_color=color.yellow)
    table.cell(cp, 1, 18, f_p(sp_price), bgcolor=color.rgb(30, 30, 30), text_color=color.yellow)

    table.cell(cp, 0, 19, "🤝 LimitPreis (LP)", bgcolor=color.rgb(50, 50, 50), text_color=color.yellow)
    table.cell(cp, 1, 19, f_p(lp_price), bgcolor=color.rgb(30, 30, 30), text_color=color.yellow)

    table.cell(cp, 0, 20, "🔢 Anzahl (Stk)", bgcolor=color.rgb(50, 50, 50), text_color=color.white)
    table.cell(cp, 1, 20, str.tostring(shares), bgcolor=color.rgb(30, 30, 30), text_color=color.white)

    table.cell(cp, 0, 21, "💸 TP (Teilverkauf)", bgcolor=color.rgb(50, 50, 50), text_color=color.lime)
    table.cell(cp, 1, 21, f_p(tp_price), bgcolor=color.rgb(30, 30, 30), text_color=color.lime)

    table.cell(cp, 0, 22, "🏁 Stopp-Loss (SL)", bgcolor=color.rgb(50, 50, 50), text_color=color.orange)
    table.cell(cp, 1, 22, f_p(sl_price), bgcolor=color.rgb(30, 30, 30), text_color=color.orange)

// ==========================================
// --- 10. VISUALS & ALARME ---
// ==========================================
var line l_sp = na, var line l_sl = na, var line l_tp = na
var label lbl_sp = na, var label lbl_sl = na, var label lbl_tp = na
if barstate.islast and w_trend != 0
    line.delete(l_sp), line.delete(l_sl), line.delete(l_tp), label.delete(lbl_sp), label.delete(lbl_sl), label.delete(lbl_tp)
    l_sp := line.new(bar_index, sp_price, bar_index + 5, sp_price, color=color.yellow, width=1, style=line.style_dashed)
    l_sl := line.new(bar_index, sl_price, bar_index + 5, sl_price, color=color.red, width=1)
    l_tp := line.new(bar_index, tp_price, bar_index + 5, tp_price, color=color.lime, width=1)
    lbl_sp := label.new(bar_index + 5, sp_price, "🎯 Entry", color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)
    lbl_sl := label.new(bar_index + 5, sl_price, "🏁 Stop", color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)
    lbl_tp := label.new(bar_index + 5, tp_price, "💸 TP", color=color.lime, textcolor=color.black, style=label.style_label_left, size=size.small)

if barstate.isrealtime and barstate.isconfirmed
    bool is_omega = vix_c > 35.0
    bool is_delta = vix_c > 25.0 and vix_c <= 35.0

    if is_omega
        // Im OMEGA-Regime feuern wir keine Entry-Alarme. Pine Script kennt kein 'pass'.
        int _dummy = 0 
    else if is_delta and (is_golden_long or is_sniper_long)
        // Reduziertes Risiko für Longs im High VIX Environment (DELTA)
        alert(mode_prefix + " - 📡 INFO/LAUERN LONG " + syminfo.ticker + ": Reduziertes Risiko (" + str.tostring(active_risk_l, "#.##") + "€). In: " + f_p(sp_price), alert.freq_once_per_bar)
    else if is_golden_long or is_golden_short
        float r_val = w_trend == 1 ? active_risk_l : active_risk_s
        alert(mode_prefix + " - 🏆 GOLDEN SETUP " + syminfo.ticker + ": Risiko " + str.tostring(r_val, "#.##") + "€. In: " + f_p(sp_price) + " | TP(1:1): " + f_p(tp_price), alert.freq_once_per_bar)
    else if is_sniper_long or is_sniper_short
        float r_val = w_trend == 1 ? active_risk_l : active_risk_s
        // DELTA Shorts landen hier, weil is_sniper_short greift
        alert(mode_prefix + " - 🎯 ACTION/FEUER FREI " + syminfo.ticker + ": Risiko " + str.tostring(r_val, "#.##") + "€. In: " + f_p(sp_price), alert.freq_once_per_bar)
    else if is_lauern_long or is_lauern_short
        alert(mode_prefix + " - 📡 RADAR " + syminfo.ticker + ": Lauer-Modus!", alert.freq_once_per_bar)