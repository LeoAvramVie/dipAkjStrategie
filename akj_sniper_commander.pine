//@version=6
indicator("AKJ 2.0 Sniper-Commander v20.7", overlay=true, max_labels_count=500)

// ==========================================
// --- 1. INPUTS ---
// ==========================================
group_rm         = "Risikomanagement"
risk_per_trade   = input.float(100.0, "Basis Risiko pro Trade (€)", group=group_rm)
limit_offset_pct = input.float(0.2, "Limit-Offset (%)", group=group_rm)
atr_stop_mult    = input.float(1.0, "ATR Stop Multiplikator (v20.6)", group=group_rm, step=0.1) // Reduziert auf 1.0 für mehr Sensitivität
use_dyn_risk     = input.bool(true, "Asymmetrisches Risk (Alpha/Delta/Omega)", group=group_rm)

group_strat      = "MK-Strategie Parameter"
bb_len           = input.int(10, "Bollinger Länge", group=group_strat)
bb_mult          = input.float(1.0, "Bollinger Multiplikator", group=group_strat)
wpr_len          = input.int(4, "Williams %R Länge", group=group_strat)
atr_len          = input.int(14, "ATR Länge (Filter/Radar)", group=group_strat)
group_vol_filter    = "Volumen Filter (v20.7 ATR-Normalisiert)"
vol_timeframe       = input.timeframe("240", "Volumen Timeframe (4H)", group=group_vol_filter)
// v20.7: ATR-normalisierte Schwellenwerte statt fixe %-Werte
// Kalibrierung: 0.75 × ATR% ≈ 1.5% bei ATR=2% (Standard-Aktie) | 2.75% bei TSLA (ATR≈3.7%)
feuer_atr_mult      = input.float(0.75, "Stop-Mauer Faktor FEUER (× ATR%)",  group=group_vol_filter, step=0.05, minval=0.1, tooltip="Dynamische Mindest-Mauer = Faktor × (ATR/Kurs × 100). 0.75 entspricht ≈1.5% bei einer Aktie mit 2% ATR. Volatile Aktien (TSLA) brauchen automatisch mehr %.")
golden_atr_mult     = input.float(1.50, "Stop-Mauer Faktor GOLDEN (× ATR%)", group=group_vol_filter, step=0.05, minval=0.1, tooltip="Dynamische Golden-Mauer = Faktor × (ATR/Kurs × 100). 1.5 entspricht ≈3.0% bei 2% ATR. Macht Golden-Status ticker-agnostisch.")
max_tp_density      = input.float(15.0, "Max. TP-Widerstand (%) (FEUER)",    group=group_vol_filter)
golden_tp_density   = input.float(8.0,  "Max. TP-Widerstand (%) (GOLDEN)",   group=group_vol_filter)

group_rs         = "Sektor & Relative Stärke (v20.5)"
use_auto_etf     = input.bool(true, "Auto-Detect Sektor", group=group_rs)
user_etf         = input.symbol("SPY", "Manueller Sektor-ETF", group=group_rs)

// ==========================================
// --- COCKPIT DARSTELLUNG ---
// ==========================================
group_cp         = "Cockpit Darstellung"
cp_size_raw      = input.string("Normal", "Cockpit-Größe", options=["Kompakt", "Normal", "Groß"], group=group_cp, tooltip="Kompakt = size.tiny (Laptop), Normal = size.small (Desktop), Groß = size.normal (großer Monitor)")
// Zeilen-Sichtbarkeit (alle standardmäßig EIN)
show_sektor      = input.bool(true,  "Zeige: 🌍 Sektor",              group=group_cp)
show_rs          = input.bool(true,  "Zeige: 💪 Rel. Stärke",         group=group_cp)
show_stage       = input.bool(true,  "Zeige: 📈 Weinstein Stage",      group=group_cp)
show_wtrend      = input.bool(true,  "Zeige: 📅 Wochentrend",          group=group_cp)
show_dtrend      = input.bool(true,  "Zeige: ☀️ Tagestrend",           group=group_cp)
show_riskometer  = input.bool(true,  "Zeige: 📊 Risk-O-Meter (1R)",    group=group_cp)
show_diagnose    = input.bool(true,  "Zeige: 🔍 Setup Diagnose",       group=group_cp)
show_riskmode    = input.bool(true,  "Zeige: 🛡️ Risk-Mode (Adaptiv)",  group=group_cp)
show_anchor      = input.bool(true,  "Zeige: ⚓ Anchor-Info",           group=group_cp)
show_vacuum      = input.bool(true,  "Zeige: 📐 Vacuum Quality",        group=group_cp)
show_wpr         = input.bool(true,  "Zeige: 🕹️ Momentum (WPR)",       group=group_cp)
show_kerze       = input.bool(true,  "Zeige: 🕯️ Kerzenregel",           group=group_cp)
show_stopins     = input.bool(true,  "Zeige: 🛡️ Stopversicherung",      group=group_cp)
show_tpwid       = input.bool(true,  "Zeige: 🚧 TP Widerstand",         group=group_cp)
show_sp          = input.bool(true,  "Zeige: 🎯 Stoppreis (SP)",        group=group_cp)
show_lp          = input.bool(true,  "Zeige: 🤝 LimitPreis (LP)",       group=group_cp)
show_anzahl      = input.bool(true,  "Zeige: 🔢 Anzahl (Stk)",          group=group_cp)
show_tp_row      = input.bool(true,  "Zeige: 💸 TP (Teilverkauf)",      group=group_cp)
show_sl          = input.bool(true,  "Zeige: 🏁 Stopp-Loss (SL)",       group=group_cp)
show_runner      = input.bool(true,  "Zeige: 🏃 Runner-Target",          group=group_cp)
show_bbzone      = input.bool(true,  "Zeige: 🔭 Bollinger Zone",         group=group_cp)
show_squeeze     = input.bool(true,  "Zeige: 🗜️ BB Squeeze",            group=group_cp)
show_rsveto      = input.bool(true,  "Zeige: 💪 RS-Veto Status",         group=group_cp)

// ==========================================
// --- ATR & Atmendes Risiko-Regime (Asymmetrisch) ---
// ==========================================
atr_val = ta.atr(atr_len)
ema21   = ta.ema(close, 21)
// v20.7: ATR als % des aktuellen Kurses → Basis für normalisierte Wall-Schwellenwerte
float atr_pct            = close > 0 ? (atr_val / close) * 100 : 2.0
float dyn_min_stop_feuer  = feuer_atr_mult  * atr_pct  // z.B. 0.75 × 2% = 1.5% bei KO; 0.75 × 5% = 3.75% bei TSLA
float dyn_min_stop_golden = golden_atr_mult * atr_pct  // z.B. 1.5  × 2% = 3.0% bei KO; 1.5  × 5% = 7.5% bei TSLA
// v20.7 Screener-Fix: VIX als single call - ATR-Proxy als Fallback wenn Screener VIX blockiert
vix_c = request.security("CBOE:VIX", "1D", close, lookahead=barmerge.lookahead_off)
// Lokaler ATR-Proxy: wenn VIX = 0 oder na (Screener-Modus), berechne Volatilitat aus ATR
float vix_proxy = (atr_pct * 8)  // ATR% * 8 ~ VIX-Aquivalent (2% ATR ~ VIX 16)
float vix_eff   = (na(vix_c) or vix_c <= 0) ? vix_proxy : vix_c  // na-safe VIX

// Risk-Regime basiert auf vix_eff (na-sicher, funktioniert im Screener)
float risk_mult_l = vix_eff < 25.0 ? 1.0 : (vix_eff <= 35.0 ? 0.25 : 0.0)
float risk_mult_s = vix_eff < 25.0 ? 1.0 : (vix_eff <= 35.0 ? 1.0  : 0.0)

float active_risk_l = use_dyn_risk ? risk_per_trade * risk_mult_l : risk_per_trade
float active_risk_s = use_dyn_risk ? risk_per_trade * risk_mult_s : risk_per_trade

bool firewall_l = use_dyn_risk and risk_mult_l == 0.0
bool firewall_s = use_dyn_risk and risk_mult_s == 0.0

string risk_mode_txt = vix_eff < 25.0 ? "ALPHA (Full)" : (vix_eff <= 35.0 ? "DELTA (Short-Bias)" : "OMEGA (Lock)")
color  risk_mode_bg  = vix_eff < 25.0 ? color.rgb(10, 60, 10) : (vix_eff <= 35.0 ? color.rgb(200, 100, 0) : color.rgb(100, 10, 10))
string rm_tooltip    = "ALPHA: Volles Risiko. DELTA: Longs gebremst (25% R), Shorts aktiv (100% R). OMEGA: Handelsstopp wegen Extrem-Volatilitat."

string mode_prefix = vix_eff < 25.0 ? "ALPHA Mode" : (vix_eff <= 35.0 ? "DELTA Mode" : "OMEGA Mode")

d_wpr = math.abs(ta.wpr(wpr_len))

// ==========================================
// --- 2. WOCHEN-DATA (Sticky & Strict) ---
// ==========================================
// v20.7 Screener-Fix: w_basis_1 in f_bb_w_hist() integriert → 2 Weekly-Calls werden zu 1
f_bb_w_hist() =>
    basis = ta.sma(close, bb_len)
    dev   = ta.stdev(close, bb_len) * bb_mult
    // Gibt 9 Werte zurck: 8 original + w_basis_1 am Ende
    [close[1], basis[1] + dev[1], basis[1] - dev[1],
     close[2], basis[2] + dev[2], basis[2] - dev[2],
     ta.sma(close, 30)[1], ta.sma(close, 30)[2],
     basis[1]]  // <-- w_basis_1 jetzt hier integriert (9. Wert)

[w_cl_1, w_up_1, w_lo_1, w_cl_2, w_up_2, w_lo_2, w_sma30_1, w_sma30_2, w_basis_1] = request.security(syminfo.tickerid, "W", f_bb_w_hist(), lookahead=barmerge.lookahead_off)
// Kein separater w_basis_1 Call mehr notwendig — v20.7 Screener-Fix (war: 2. Weekly-Security-Call)

var int w_trend = 0 
if w_cl_1 > w_up_1 and w_cl_2 > w_up_2
    w_trend := 1
else if w_cl_1 < w_lo_1 and w_cl_2 < w_lo_2
    w_trend := -1
else if w_trend == 1 and w_cl_1 < w_basis_1  // Fix v20.6: Midline-Reset – Trend pausiert wenn Wochenkurs unter Basis fällt
    w_trend := 0
else if w_trend == -1 and w_cl_1 > w_basis_1  // Fix v20.6: Midline-Reset – Trend pausiert wenn Wochenkurs über Basis steigt
    w_trend := 0

int weinstein_stage = 0
if w_cl_1 > w_sma30_1 and w_sma30_1 > w_sma30_2
    weinstein_stage := 2
else if w_cl_1 < w_sma30_1 and w_sma30_1 < w_sma30_2
    weinstein_stage := 4

string ws_txt = weinstein_stage == 2 ? "STAGE 2 OK Long ✅" : weinstein_stage == 4 ? "STAGE 4 OK Short ✅" : "SEITWÄRTS"
color  ws_bg  = weinstein_stage == 2 ? color.blue : weinstein_stage == 4 ? color.red : color.rgb(30, 30, 30)

// --- Anchor Logic (v20.5) ---
var int stage_change_bar = bar_index
if ta.change(weinstein_stage) != 0
    stage_change_bar := bar_index

int anchor_bars = math.max(1, bar_index - stage_change_bar)
if anchor_bars > 300
    anchor_bars := 300 // CPU Saver

// ==========================================
// --- 3. TAGES-LOGIK (Sticky Trend Hysterese v20.5) ---
// ==========================================
[d_basis, d_up, d_lo] = ta.bb(close, bb_len, bb_mult)
atr_buffer = atr_val * 0.2

var bool setup_strict_long  = false
var bool setup_strict_short = false

if close[1] > d_up[1] + atr_buffer and close[2] > d_up[2] + atr_buffer
    setup_strict_long := true
if close[1] < d_lo[1] - atr_buffer and close[2] < d_lo[2] - atr_buffer
    setup_strict_short := true

if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_long := false
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_short := false
// Scharf-Modus bleibt bis zum unteren Band aktiv (80% Dip-Käufer: WPR-Signal an der Mittellinie ist der beste Entry!)
// w_trend Midline-Reset läuft unabhängig auf Wochenbasis (Fix 1 bleibt).  Guard entfernt in v20.6b.

bool is_doji = math.abs(close - open) < (atr_val * 0.1)

// ==========================================
// --- 4. PREIS-BERECHNUNG ---
// ==========================================
float atr_stop_dist = atr_val * atr_stop_mult

float sp_long  = high
float sl_long  = low - atr_stop_dist
float r_l = math.max(math.abs(sp_long - sl_long) * syminfo.pointvalue, syminfo.mintick)
float tp_long = sp_long + (sp_long - sl_long)
int shares_l = int(math.floor(active_risk_l / r_l))

float sp_short = low
float sl_short = high + atr_stop_dist
float r_s = math.max(math.abs(sp_short - sl_short) * syminfo.pointvalue, syminfo.mintick)
float tp_short = sp_short - (sl_short - sp_short)
int shares_s = int(math.floor(active_risk_s / r_s))

float sp_price = w_trend == -1 ? sp_short : sp_long
float sl_price = w_trend == -1 ? sl_short : sl_long
int   shares   = w_trend == -1 ? shares_s : shares_l
float risk_val = w_trend == -1 ? r_s : r_l
float lp_price = w_trend == -1 ? sp_price * (1 - limit_offset_pct / 100) : sp_price * (1 + limit_offset_pct / 100)
float tp_price = w_trend == -1 ? sp_price - risk_val : sp_price + risk_val
float active_risk_display = w_trend == -1 ? active_risk_s : active_risk_l

// ==========================================
// --- 5. VOLUMEN-STRUKTUR ---
// ==========================================
f_calc_tf_vol_anchored(sp, sl, tp, lookback, do_calc) =>
    float s_dens = 0.0
    float t_dens = 0.0
    float avg_v = 0.0
    float zone_vol_s = 0.0
    float zone_vol_t = 0.0
    float total_v    = 0.0
    float upper_s = math.max(sp, sl), float lower_s = math.min(sp, sl)
    float upper_t = math.max(sp, tp), float lower_t = math.min(sp, tp)
    int lb = math.min(lookback, 300)
    if lb > 0 and do_calc
        for i = 0 to lb - 1
            float bar_h = high[i], float bar_l = low[i], float bar_vol = volume[i]
            total_v += bar_vol
            float bar_range = bar_h - bar_l
            if bar_range > 0
                float intersect_s = math.max(0, math.min(bar_h, upper_s) - math.max(bar_l, lower_s))
                zone_vol_s += bar_vol * (intersect_s / bar_range)
                float intersect_t = math.max(0, math.min(bar_h, upper_t) - math.max(bar_l, lower_t))
                zone_vol_t += bar_vol * (intersect_t / bar_range)
        avg_v := total_v / lb
        if total_v > 0
            s_dens := (zone_vol_s / total_v) * 100
            t_dens := (zone_vol_t / total_v) * 100
    [s_dens, t_dens, avg_v]

// Performance-Gate: Nur extrem rechenintensive Loops zulassen für Live-Zustand oder aktuelle Alarmlogik
bool lazy_gate = barstate.islast or (bar_index >= last_bar_index - 1000)

[stop_density, tp_density, avg_anchor_vol] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol_anchored(sp_price, sl_price, tp_price, anchor_bars, lazy_gate))

// lower_tf_vol_arr & rld_pct were removed to save performance (unused in v20.7)
bool vacuum_ok = tp_density <= max_tp_density
string vacuum_qual = vacuum_ok ? ("High (TP " + str.tostring(tp_density, "#.#") + "%)") : ("Low (TP " + str.tostring(tp_density, "#.#") + "%)")

// ==========================================
// --- 5b. BOLLINGER CHECK & ZONEN ---
// ==========================================
bc_basis = ta.sma(close, 10)
bc_dev = ta.stdev(close, 10) * 1.0
bc_ub = bc_basis + bc_dev
bc_lb = bc_basis - bc_dev
bc_unit = (bc_ub - bc_lb) / 12

string bc_txt = "NEUTRAL"
color bc_bg = color.new(color.gray, 50)

if close > bc_ub
    bc_txt := "SHORT (EXTREME)"
    bc_bg := color.new(color.maroon, 10)
else if close >= bc_lb + (8 * bc_unit)
    bc_txt := "SHORT ZONE"
    bc_bg := color.new(color.red, 20)
else if close >= bc_lb + (4 * bc_unit)
    bc_txt := "NEUTRAL"
    bc_bg := color.new(color.gray, 50)
else if close >= bc_lb
    bc_txt := "LONG ZONE"
    bc_bg := color.new(color.blue, 20)
else
    bc_txt := "LONG (EXTREME)"
    bc_bg := color.new(color.navy, 10)

bool is_momentum_l = setup_strict_long
bool is_momentum_s = setup_strict_short

bool is_correct_zone_l = (bc_txt == "LONG ZONE" or bc_txt == "LONG (EXTREME)") or is_momentum_l
bool is_correct_zone_s = (bc_txt == "SHORT ZONE" or bc_txt == "SHORT (EXTREME)") or is_momentum_s

// ==========================================
// --- 6. SIGNAL-IDENTIFIKATION (Zero-Latency Sync) ---
// ==========================================

// Radar (Hysterese + Sticky State)
bool is_radar_l = high >= d_up + (atr_val * 0.2)
bool radar_state_l = weinstein_stage == 2 and (is_radar_l or setup_strict_long)

bool is_radar_s = low <= d_lo - (atr_val * 0.2)
bool radar_state_s = weinstein_stage == 4 and (is_radar_s or setup_strict_short)

// Raw Triggers (WPR + Kerzenregel)
bool long_trigger = d_wpr >= 80 and close < open and not is_doji and close > d_lo
bool short_trigger = d_wpr <= 20 and close > open and not is_doji and close < d_up

// Volumen (Wall & Vakuum)
// v20.7: ATR-normalisierte Schwellenwerte (ticker-agnostisch)
bool vol_feuer_l  = stop_density >= dyn_min_stop_feuer  and tp_density <= max_tp_density
bool vol_feuer_s  = stop_density >= dyn_min_stop_feuer  and tp_density <= max_tp_density
bool vol_golden_l = stop_density >= dyn_min_stop_golden and tp_density <= golden_tp_density
bool vol_golden_s = stop_density >= dyn_min_stop_golden and tp_density <= golden_tp_density

// --- SYNCHRONIZED TRIGGER BOOLS ---
bool trigger_lauern_l = radar_state_l and d_wpr < 80
bool trigger_lauern_s = radar_state_s and d_wpr > 20

bool raw_feuer_l = radar_state_l and long_trigger
bool raw_feuer_s = radar_state_s and short_trigger

// v20.7: RS-Veto — GOLDEN und AKJ ELITE nur wenn Relative Stärke nicht SCHWACH (perf_diff > -2.0)
// perf_diff wird erst nach request.security berechnet (Zeile ~470) → var bool mit Defaultwert true
// Nach der perf_diff Berechnung wird rs_ok_for_premium aktualisiert
var bool rs_ok_for_premium = true  // Default: kein Veto (wird unten überschrieben)

bool trigger_feuer_l  = raw_feuer_l and is_correct_zone_l
bool trigger_feuer_s  = raw_feuer_s and is_correct_zone_s

bool trigger_golden_l = raw_feuer_l and vol_golden_l and is_correct_zone_l and rs_ok_for_premium  // v20.7: RS-Veto
bool trigger_golden_s = raw_feuer_s and vol_golden_s and is_correct_zone_s and rs_ok_for_premium

// AKJ Elite Signal (v20.7: RS-Veto hinzugefügt)
bool isAKJSignal_l = weinstein_stage == 2 and setup_strict_long  and d_wpr >= 80 and low  > d_lo and open != close and rs_ok_for_premium
bool isAKJSignal_s = weinstein_stage == 4 and setup_strict_short and d_wpr <= 20 and high < d_up and open != close and rs_ok_for_premium
bool isAKJSignal = isAKJSignal_l or isAKJSignal_s

type VirtualTrade
    int   t_class // 1 = Lauern, 2 = Feuer Frei, 3 = Golden
    int   dir     // 1 = Long, -1 = Short
    float ep
    float sl
    float tp
    float r_dist
    bool  tp1_hit
    int   entry_bar

var virtual_trades = array.new<VirtualTrade>()

// Stat-Counter (Closed Trades: Win vs Loss)
var int w_lauern = 0
var int w_feuer = 0
var int w_golden = 0

var int l_lauern = 0
var int l_feuer = 0
var int l_golden = 0

var float p_lauern = 0.0
var float p_feuer = 0.0
var float p_golden = 0.0

var int total_missed_omega = 0



// Evaluierung offener virtueller Trades
if array.size(virtual_trades) > 0
    for i = array.size(virtual_trades) - 1 to 0
        VirtualTrade vt = array.get(virtual_trades, i)
        
        bool sl_hit = false
        bool tp_hit = false
        bool runner_exit = false
        bool time_exit = (bar_index - vt.entry_bar) >= 5
        
        if vt.dir == 1
            if low <= vt.sl
                sl_hit := true
            if not vt.tp1_hit and high >= vt.tp
                tp_hit := true
            if vt.tp1_hit and (close < ema21 or w_trend == -1 or time_exit) // Runner Exit
                runner_exit := true
        else
            if high >= vt.sl
                sl_hit := true
            if not vt.tp1_hit and low <= vt.tp
                tp_hit := true
            if vt.tp1_hit and (close > ema21 or w_trend == 1 or time_exit) // Runner Exit
                runner_exit := true
                
        // Pessimistischer Ansatz
        if sl_hit and tp_hit
            tp_hit := false
            
        if not vt.tp1_hit
            // Erster Teil: SL vs TP1
            if sl_hit or (time_exit and not tp_hit)
                float exit_r = -1.0
                if not sl_hit
                    exit_r := vt.dir == 1 ? (close - vt.ep) / vt.r_dist : (vt.ep - close) / vt.r_dist
                
                if vt.t_class == 1
                    if exit_r > 0
                        w_lauern += 1
                    else
                        l_lauern += 1
                    p_lauern += exit_r
                else if vt.t_class == 2
                    if exit_r > 0
                        w_feuer += 1
                    else
                        l_feuer += 1
                    p_feuer += exit_r
                else
                    if exit_r > 0
                        w_golden += 1
                    else
                        l_golden += 1
                    p_golden += exit_r
                array.remove(virtual_trades, i)
            else if tp_hit
                // 1:1 erreicht! 50% TP, Rest auf Break-Even
                if vt.t_class == 1
                    w_lauern += 1
                else if vt.t_class == 2
                    w_feuer += 1
                else
                    w_golden += 1
                
                vt.tp1_hit := true
                vt.sl := vt.ep
        else
            // Zweiter Teil: Runner Trailing Start
            if sl_hit or runner_exit
                float exit_r = 0.0
                if not sl_hit
                    float act_exit_p = close // Exit am aktuellen Kerzenschluss nach Crossing
                    exit_r := vt.dir == 1 ? (act_exit_p - vt.ep) / vt.r_dist : (vt.ep - act_exit_p) / vt.r_dist
                
                // Gesamtes R = 50% initial (1.0 R) + 50% runner (exit_r)
                float total_r = (0.5 * 1.0) + (0.5 * exit_r)
                
                if vt.t_class == 1
                    p_lauern += total_r
                else if vt.t_class == 2
                    p_feuer += total_r
                else
                    p_golden += total_r
                    
                array.remove(virtual_trades, i)

// Hilfsfunktion: Prüft, ob ein virtueller Trade mit gleicher Klasse & Richtung schon aktiv ist (Lock-Check)
f_is_active(int t_class, int dir) =>
    bool active = false
    if array.size(virtual_trades) > 0
        for i = 0 to array.size(virtual_trades) - 1
            VirtualTrade vt = array.get(virtual_trades, i)
            if vt.t_class == t_class and vt.dir == dir
                active := true
                break
    active

// Event-Zähler (Nur ansteuern, wenn Zustand NEU oder nach Lock-Freigabe wieder möglich ist)
bool evt_lauern_l = trigger_lauern_l and not trigger_lauern_l[1]
bool evt_feuer_l  = trigger_feuer_l  and not trigger_feuer_l[1]
bool evt_golden_l = trigger_golden_l and not trigger_golden_l[1]

bool evt_lauern_s = trigger_lauern_s and not trigger_lauern_s[1]
bool evt_feuer_s  = trigger_feuer_s  and not trigger_feuer_s[1]
bool evt_golden_s = trigger_golden_s and not trigger_golden_s[1]

// Neue Setups ins Audit einspeisen (LONG Event-Based)
if evt_lauern_l and not f_is_active(1, 1)
    array.push(virtual_trades, VirtualTrade.new(1, 1, sp_long, sl_long, tp_long, sp_long - sl_long, false, bar_index))
if evt_feuer_l and not f_is_active(2, 1)
    array.push(virtual_trades, VirtualTrade.new(2, 1, sp_long, sl_long, tp_long, sp_long - sl_long, false, bar_index))
if evt_golden_l
    if not f_is_active(3, 1)
        array.push(virtual_trades, VirtualTrade.new(3, 1, sp_long, sl_long, tp_long, sp_long - sl_long, false, bar_index))

// Neue Setups ins Audit einspeisen (SHORT Event-Based)
if evt_lauern_s and not f_is_active(1, -1)
    array.push(virtual_trades, VirtualTrade.new(1, -1, sp_short, sl_short, tp_short, sl_short - sp_short, false, bar_index))
if evt_feuer_s and not f_is_active(2, -1)
    array.push(virtual_trades, VirtualTrade.new(2, -1, sp_short, sl_short, tp_short, sl_short - sp_short, false, bar_index))
if evt_golden_s
    if not f_is_active(3, -1)
        array.push(virtual_trades, VirtualTrade.new(3, -1, sp_short, sl_short, tp_short, sl_short - sp_short, false, bar_index))

// ==========================================
// --- 7. SEKTOR & RELATIVE STÄRKE ---
// ==========================================
f_get_auto_sector() =>
    string etf   = "SPY"
    string sec   = syminfo.sector
    string ind   = syminfo.industry
    string sname = sec != "" ? sec : "S&P 500 Index"
    
    if use_auto_etf
        if ind == "Aerospace & Defense"
            etf := "ITA"
            sname := "Rüstung & Aero"
        else if ind == "Semiconductors"
            etf := "SMH"
            sname := "Halbleiter"
        else if sec == "Electronic Technology" or sec == "Technology Services"
            etf := "XLK"
        else if sec == "Energy Minerals"
            etf := "XLE"
        else if sec == "Finance" or sec == "Commercial Services"
            etf := "XLF"
        else if sec == "Health Technology" or sec == "Health Services"
            etf := "XLV"
        else if sec == "Producer Manufacturing" or sec == "Industrial Services"
            etf := "XLI"
        else if sec == "Consumer Durables" or sec == "Retail Trade" or sec == "Consumer Services"
            etf := "XLY"
        else if sec == "Consumer Non-Durables" or sec == "Process Industries"
            etf := "XLP"
        else if sec == "Non-Energy Minerals"
            etf := "XLB"
        else if sec == "Communications"
            etf := "XLC"
        else if sec == "Utilities"
            etf := "XLU"
        else if sec == "Real Estate"
            etf := "XLRE"
    
    if not use_auto_etf or etf == "SPY"
        etf := user_etf
        sname := user_etf == "SPY" ? "S&P 500" : (sec != "" ? sec : "Index/ETF")
        
    [etf, sname]

[sector_ticker, sector_name] = f_get_auto_sector()
[etf_c, etf_sma, etf_c20] = request.security(sector_ticker, "1D", [close, ta.sma(close, 10), close[20]], lookahead=barmerge.lookahead_off)

bool sector_long = etf_c > etf_sma
string sec_txt = sector_name + " (" + sector_ticker + ")"
color sec_bg = sector_long ? color.blue : color.red

float stock_perf = close[20] != 0 ? ((close - close[20]) / close[20]) * 100 : 0.0
float etf_perf   = etf_c20 != 0 ? ((etf_c - etf_c20) / etf_c20) * 100 : 0.0
float perf_diff  = stock_perf - etf_perf

// v20.7: RS-Veto jetzt aktualisieren (perf_diff ist jetzt bekannt)
// GOLDEN und AKJ ELITE werden blockiert wenn RS = SCHWACH (Aktie underperformt Sektor um >2%)
rs_ok_for_premium := perf_diff > -2.0

string rs_txt = perf_diff > 2.0 ? "STARK" : perf_diff < -2.0 ? "SCHWACH" : "MITTEL"
color  rs_bg  = perf_diff > 2.0 ? color.blue : perf_diff < -2.0 ? color.red : color.rgb(30, 30, 30)

// v20.7: Bollinger Squeeze Anzeige
float bb_width_pct = d_basis > 0 ? ((d_up - d_lo) / d_basis) * 100 : 0.0
string squeeze_txt = bb_width_pct < 3.0 ? "🗜️ SQUEEZE (" + str.tostring(bb_width_pct, "#.#") + "%)" : (bb_width_pct > 8.0 ? "💥 EXPANSION (" + str.tostring(bb_width_pct, "#.#") + "%)" : "NORMAL (" + str.tostring(bb_width_pct, "#.#") + "%)")
color  squeeze_bg  = bb_width_pct < 3.0 ? color.rgb(0, 50, 120) : (bb_width_pct > 8.0 ? color.rgb(100, 20, 20) : color.rgb(30, 30, 30))

// ==========================================
// --- 8. UI LOGIK & FARBEN ---
// ==========================================
color color_himmelblau = color.rgb(0, 191, 255)
color color_hellrot = color.rgb(240, 128, 128)
color color_gold = color.rgb(13, 255, 0)

// Trend UI Strings
string wt_txt = w_trend == 1 ? "BULLISCH ⬆️ (Sticky)" : w_trend == -1 ? "BÄRISCH ⬇️ (Sticky)" : "NEUTRAL ↔️"
color  wt_bg  = w_trend == 1 ? color.blue : w_trend == -1 ? color.red : color.rgb(30, 30, 30)

bool is_in_radar_long = close[1] > d_up[1] or setup_strict_long
bool is_in_radar_short = close[1] < d_lo[1] or setup_strict_short

string dt_txt = setup_strict_long ? "LONG (Scharf)" : setup_strict_short ? "SHORT (Scharf)" : is_in_radar_long ? "LONG (Radar)" : is_in_radar_short ? "SHORT (Radar)" : "NEUTRAL"
color  dt_bg  = setup_strict_long ? color.blue : setup_strict_short ? color.red : (is_in_radar_long or is_in_radar_short) ? color.yellow : color.rgb(30, 30, 30)

// Candles
string c_txt = ""
color  c_bg  = color.rgb(30, 30, 30)
if w_trend == 1
    c_txt := (close < open and not is_doji) ? "OK ✅" : "WAIT ⏳"
    c_bg  := (close < open and not is_doji) ? color.blue : color.rgb(30, 30, 30)
else if w_trend == -1
    c_txt := (close > open and not is_doji) ? "OK ✅" : "WAIT ⏳"
    c_bg  := (close > open and not is_doji) ? color.red : color.rgb(30, 30, 30)

// Highlight overrides
if raw_feuer_l or raw_feuer_s or trigger_golden_l or trigger_golden_s
    c_bg := (raw_feuer_l or trigger_golden_l) ? color.blue : color.red
    wt_bg := c_bg
    dt_bg := c_bg

// Cooldown Logic & State Tracker (v20.7.2 Atomic Gate)
var int last_fired_time = 0
var string last_fired_status = ""
var string last_tac_txt = ""

int remaining_locked_ms = 180000 - (timenow - nz(last_fired_time))
bool cooldown_over = remaining_locked_ms <= 0

string header_txt = "NO SIGNAL"
color header_bg = color.black
// Cockpit UI-Sync (WPR Gatekeeper)
bool is_wpr_trig_l = d_wpr >= 80
bool is_wpr_trig_s = d_wpr <= 20

bool is_lauern_l = radar_state_l and not is_wpr_trig_l
bool is_lauern_s = radar_state_s and not is_wpr_trig_s

string t_mode_l = is_momentum_l ? " (MOM)" : ""
string t_mode_s = is_momentum_s ? " (MOM)" : ""
string short_mode = vix_c < 25.0 ? "ALPHA" : (vix_c <= 35.0 ? "DELTA" : "OMEGA")

if isAKJSignal_l or isAKJSignal_s
    header_txt := "💎 AKJ ELITE (" + short_mode + ")" + (isAKJSignal_l ? t_mode_l : t_mode_s)
    header_bg := color.fuchsia
else if trigger_golden_l or trigger_golden_s
    header_txt := "🌟 GOLDEN (" + short_mode + ")" + (trigger_golden_l ? t_mode_l : t_mode_s)
    header_bg := color.lime
else if trigger_feuer_l or trigger_feuer_s
    header_txt := "🟢 FEUER FREI (" + short_mode + ")" + (trigger_feuer_l ? t_mode_l : t_mode_s)
    header_bg := color.rgb(0, 100, 0)
else if is_lauern_l or is_lauern_s
    header_txt := "📡 LAUERN (" + short_mode + ")" + (is_lauern_l ? t_mode_l : t_mode_s)
    header_bg := color.rgb(150, 150, 0)

string diagnose_txt = "-"
color diag_c = color.silver
if raw_feuer_l or raw_feuer_s
    if not is_correct_zone_l and not is_correct_zone_s
        diagnose_txt := "❌ FAILED: Zonen-Check verfehlt"
        diag_c := color.red
    else if not vol_golden_l and not vol_golden_s
        diagnose_txt := "⚠️ MISSING: Golden Volumen (>3%)"
        diag_c := color.orange
    else
        diagnose_txt := "💎 PREMIUM: Alle Checks OK (Golden)"
        diag_c := color.lime
else if is_lauern_l or is_lauern_s
    diagnose_txt := "⏳ WAIT: Warten auf Momentum (WPR)"
    diag_c := color.yellow

if not cooldown_over and header_txt != "NO SIGNAL"
    header_txt := header_txt + " [Wait:" + str.tostring(math.round(remaining_locked_ms / 1000)) + "s]"

// ==========================================
// --- 9. COCKPIT UI ---
// ==========================================
// Plan B: Dynamische Zeilenzählung — nur sichtbare Zeilen bekommen Platz
// Textgröße basiert auf Cockpit-Größe Input
f_p(val) => na(val) ? "-" : str.tostring(val, "#.##")

// Bestimme Textgrößen basierend auf Cockpit-Größe
cp_txt_main  = cp_size_raw == "Kompakt" ? size.tiny   : (cp_size_raw == "Groß" ? size.normal : size.small)
cp_txt_hdr   = cp_size_raw == "Kompakt" ? size.small  : (cp_size_raw == "Groß" ? size.large  : size.normal)
cp_txt_sep   = cp_size_raw == "Kompakt" ? size.tiny   : size.small

// Gruppen-Sichtbarkeit (Trennlinie nur wenn mindestens 1 Zeile der Gruppe sichtbar)
bool grp_markt  = show_sektor or show_rs or show_stage
bool grp_trend  = show_wtrend or show_dtrend
bool grp_sniper = show_riskometer or show_riskmode or show_anchor or show_vacuum
bool grp_signal = show_diagnose or show_wpr or show_kerze or show_stopins or show_tpwid
bool grp_order  = show_sp or show_lp or show_anzahl or show_tp_row or show_sl or show_runner
bool grp_zusatz = show_bbzone or show_squeeze or show_rsveto

// Dynamische Zeilenzählung
int n = 1  // Row 0 = STATUS Header immer da
if grp_markt
    n += 1  // Trennlinie MARKT-KONTEXT
if show_sektor
    n += 1
if show_rs
    n += 1
if show_stage
    n += 1
if grp_trend
    n += 1  // Trennlinie TREND-ANALYSE
if show_wtrend
    n += 1
if show_dtrend
    n += 1
if grp_sniper
    n += 1  // Trennlinie SNIPER METRIKEN
if show_riskometer
    n += 1
if show_riskmode
    n += 1
if show_anchor
    n += 1
if show_vacuum
    n += 1
if grp_signal
    n += 1  // Trennlinie SIGNAL-VALIDIERUNG
if show_diagnose
    n += 1
if show_wpr
    n += 1
if show_kerze
    n += 1
if show_stopins
    n += 1
if show_tpwid
    n += 1
if grp_order
    n += 1  // Trennlinie ORDER-MATRIX
if show_sp
    n += 1
if show_lp
    n += 1
if show_anzahl
    n += 1
if show_tp_row
    n += 1
if show_sl
    n += 1
if show_runner
    n += 1
if grp_zusatz
    n += 1  // Trennlinie ZUSATZ-INFO
if show_bbzone
    n += 1
if show_squeeze
    n += 1
if show_rsveto
    n += 1


// Tabelle: deklariert als var, wird auf letztem Bar neu erstellt mit exakt n Zeilen
var table cp = table.new(position.top_right, 2, 29, border_width=1, border_color=color.new(color.white, 80), frame_width=1, frame_color=color.new(color.white, 80))

if barstate.islast
    // Plan B: Tabelle löschen und mit korrekter Zeilenzahl neu erstellen
    table.delete(cp)
    cp := table.new(position.top_right, 2, n, border_width=1, border_color=color.new(color.white, 80), frame_width=1, frame_color=color.new(color.white, 80))
    color h_tc = (header_bg == color.yellow or header_bg == color.lime) ? color.black : color.white
    color dt_tc = (dt_bg == color.yellow) ? color.black : color.white
    string rom_str = str.tostring(nz(active_risk_display), "#.##") + " €"
    string anc_str = str.tostring(nz(anchor_bars)) + " Bars ago"
    string wpr_txt = str.tostring(nz(d_wpr), "#.#")
    color wpr_bg = color.rgb(40, 40, 40)
    if w_trend == 1
        wpr_bg := nz(d_wpr) >= 80 ? color.blue : (nz(d_wpr) >= 70 ? color.yellow : color.rgb(40, 40, 40))
    else if w_trend == -1
        wpr_bg := nz(d_wpr) <= 20 ? color.red : (nz(d_wpr) <= 30 ? color.yellow : color.rgb(40, 40, 40))
    color wpr_tc = (wpr_bg == color.yellow) ? color.black : color.white
    color s_v_bg = nz(stop_density) >= dyn_min_stop_feuer ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)
    string sd_str = str.tostring(nz(stop_density), "#.#") + "%"
    color t_v_bg = vacuum_ok ? color.rgb(10, 60, 10) : color.rgb(60, 10, 10)
    string tp_str = str.tostring(nz(tp_density), "#.#") + "%"
    string shares_display = nz(shares) > 0 ? str.tostring(nz(shares)) : "Min: 1 (Risk > Budget)"
    color ema_col = w_trend == 1 ? color.blue : (w_trend == -1 ? color.red : color.rgb(80, 80, 80))
    string ema_str = "EMA 21: " + f_p(ema21)
    string rs_veto_txt = rs_ok_for_premium ? "✅ (Golden/Elite OK)" : "⚠️ VETO (RS SCHWACH — kein Golden/Elite)"
    color  rs_veto_bg  = rs_ok_for_premium ? color.rgb(10, 50, 10) : color.rgb(70, 20, 0)
    string dyn_feuer_str  = str.tostring(dyn_min_stop_feuer,  "#.##") + "%"
    string dyn_golden_str = str.tostring(dyn_min_stop_golden, "#.##") + "%"

    // Laufender Zeilen-Index (r) — wächst nur wenn Zeile sichtbar ist
    int r = 0

    // Row 0: STATUS Header (immer sichtbar)
    table.cell(cp, 0, r, " STATUS ", bgcolor=color.black, text_color=color.white, text_size=cp_txt_hdr)
    table.cell(cp, 1, r, header_txt, bgcolor=header_bg, text_color=h_tc, text_size=cp_txt_hdr)
    r += 1

    // MARKT-KONTEXT Gruppe
    if grp_markt
        table.cell(cp, 0, r, "--- MARKT-KONTEXT ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=cp_txt_sep, text_halign=text.align_center)
        table.merge_cells(cp, 0, r, 1, r)
        r += 1
    if show_sektor
        table.cell(cp, 0, r, "🌍 Sektor", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Der maßgebliche Sektor-ETF der Aktie. Dient zur Bestimmung des Marktumfelds und der relativen Stärke.")
        table.cell(cp, 1, r, sec_txt, bgcolor=sec_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_rs
        table.cell(cp, 0, r, "💪 Rel. Stärke", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Vergleicht die Performance der Aktie mit ihrem Sektor über 20 Tage. STARK bedeutet Outperformance und erhöht die Wahrscheinlichkeit für einen erfolgreichen Trade.")
        table.cell(cp, 1, r, rs_txt, bgcolor=rs_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_stage
        table.cell(cp, 0, r, "📈 Weinstein Stage", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Strategische Marktphase nach Stan Weinstein. Stage 2 = Institutionelle Akkumulation (Long), Stage 4 = Institutionelle Distribution (Short).")
        table.cell(cp, 1, r, ws_txt, bgcolor=ws_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1

    // TREND-ANALYSE Gruppe
    if grp_trend
        table.cell(cp, 0, r, "--- TREND-ANALYSE (v20.6) ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=cp_txt_sep, text_halign=text.align_center)
        table.merge_cells(cp, 0, r, 1, r)
        r += 1
    if show_wtrend
        table.cell(cp, 0, r, "📅 Wochentrend", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Taktische Richtung auf Wochenbasis (Sticky). Erfordert 2 Schlusskurse außerhalb der Bollinger Bänder (10/1). Bleibt aktiv, bis die Gegenseite 2 Kerzen erzwingt.")
        table.cell(cp, 1, r, wt_txt, bgcolor=wt_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_dtrend
        table.cell(cp, 0, r, "☀️ Tagestrend", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Kurzfristiges Timing-Radar. Nutzt einen dynamischen ATR-Puffer (Hysterese v20.5), um Fehlsignale in volatilen Phasen (VIX > 25) zu filtern.")
        table.cell(cp, 1, r, dt_txt, bgcolor=dt_bg, text_color=dt_tc, text_size=cp_txt_main)
        r += 1

    // SNIPER METRIKEN Gruppe
    if grp_sniper
        table.cell(cp, 0, r, "--- SNIPER METRIKEN ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=cp_txt_sep, text_halign=text.align_center)
        table.merge_cells(cp, 0, r, 1, r)
        r += 1
    if show_riskometer
        table.cell(cp, 0, r, "📊 Risk-O-Meter (1R)", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Dynamische Positionsgröße (1R). Passt das Risiko basierend auf der Marktangst (VIX) und der Aktien-Volatilität automatisch an.")
        table.cell(cp, 1, r, rom_str, bgcolor=color.rgb(30,30,30), text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_riskmode
        table.cell(cp, 0, r, "🛡️ Risk-Mode (Adaptiv)", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip=rm_tooltip)
        table.cell(cp, 1, r, risk_mode_txt, bgcolor=risk_mode_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_anchor
        table.cell(cp, 0, r, "⚓ Anchor-Info", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Startpunkt des Anchored Volume Profile (AVP). Misst das Volumen exakt ab dem letzten Weinstein-Phasenwechsel oder Pivot-Punkt.")
        table.cell(cp, 1, r, anc_str, bgcolor=color.rgb(30,30,30), text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_vacuum
        table.cell(cp, 0, r, "📐 Vacuum Quality", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Prüft den historischen Ziel-Widerstand (TP < 8%). Der RLD-Current-Volumen Check blockiert Trades nicht mehr fälschlicherweise bei Breakouts.")
        table.cell(cp, 1, r, vacuum_qual, bgcolor=vacuum_ok ? color.rgb(0,180,0) : color.rgb(60,10,10), text_color=color.white, text_size=cp_txt_main)
        r += 1

    // SIGNAL-VALIDIERUNG Gruppe
    if grp_signal
        table.cell(cp, 0, r, "--- SIGNAL-VALIDIERUNG ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=cp_txt_sep, text_halign=text.align_center)
        table.merge_cells(cp, 0, r, 1, r)
        r += 1
    if show_diagnose
        table.cell(cp, 0, r, "🔍 Setup Diagnose", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Live-Prüfung warum das Setup aktuell nicht die nächsthöhere Signalstufe erreicht (z.B. fehlendes Goldenes Volumen).")
        table.cell(cp, 1, r, diagnose_txt, bgcolor=color.rgb(30,30,30), text_color=diag_c, text_size=cp_txt_main)
        r += 1
    if show_wpr
        table.cell(cp, 0, r, "🕹️ Momentum (WPR)", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Williams %R (4). Kaskade: 70/30 für Radar, 80/20 für Sniper-Einstieg.")
        table.cell(cp, 1, r, wpr_txt, bgcolor=wpr_bg, text_color=wpr_tc, text_size=cp_txt_main)
        r += 1
    if show_kerze
        table.cell(cp, 0, r, "🕯️ Kerzenregel", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Prüft die Preis-Aktion (Scharf-Kerze) inkl. ATR-basiertem Doji-Filter. OK bedeutet: Die Käufer/Verkäufer haben die Kontrolle übernommen.")
        table.cell(cp, 1, r, c_txt, bgcolor=c_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_stopins
        table.cell(cp, 0, r, "🛡️ Stopversicherung", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="v20.7 ATR-norm.: Min. FEUER=" + dyn_feuer_str + " | Min. GOLDEN=" + dyn_golden_str + " (dynamisch je Aktie-Volatilität)")
        table.cell(cp, 1, r, sd_str, bgcolor=s_v_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_tpwid
        table.cell(cp, 0, r, "🚧 TP Widerstand", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="Das Volumen-Hindernis (🚧) bis zum Ziel. Gemessen per RLD-Verfahren (v20.5). Zielwert: <8% für einen freien Lauf (Vakuum) zum Take-Profit.")
        table.cell(cp, 1, r, tp_str, bgcolor=t_v_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1

    // ORDER-MATRIX Gruppe
    if grp_order
        table.cell(cp, 0, r, "--- ORDER-MATRIX ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=cp_txt_sep, text_halign=text.align_center)
        table.merge_cells(cp, 0, r, 1, r)
        r += 1
    if show_sp
        table.cell(cp, 0, r, "🎯 Stoppreis (SP)", bgcolor=color.rgb(50,50,50), text_color=color.yellow, text_size=cp_txt_main, tooltip="Dein Einstiegs-Preis (Trigger). Platziere hier deine Stop-Buy (Long) oder Stop-Sell (Short) Limit-Order.")
        table.cell(cp, 1, r, f_p(sp_price), bgcolor=color.rgb(30,30,30), text_color=color.yellow, text_size=cp_txt_main)
        r += 1
    if show_lp
        table.cell(cp, 0, r, "🤝 LimitPreis (LP)", bgcolor=color.rgb(50,50,50), text_color=color.yellow, text_size=cp_txt_main, tooltip="Gap-Schutz für deine Einstiegsorder. Vermeidet Slippage, wenn der Markt extem wild über deinen Preis springt.")
        table.cell(cp, 1, r, f_p(lp_price), bgcolor=color.rgb(30,30,30), text_color=color.yellow, text_size=cp_txt_main)
        r += 1
    if show_anzahl
        table.cell(cp, 0, r, "🔢 Anzahl (Stk)", bgcolor=color.rgb(50,50,50), text_color=color.white, text_size=cp_txt_main, tooltip="Die Anzahl an Aktien, mit denen du EXAKT dein gewünschtes asymmetrisches (€) 1R Risiko triffst.")
        table.cell(cp, 1, r, shares_display, bgcolor=color.rgb(30,30,30), text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_tp_row
        table.cell(cp, 0, r, "💸 TP (Teilverkauf)", bgcolor=color.rgb(50,50,50), text_color=color.lime, text_size=cp_txt_main, tooltip="Das 1:1 CRV Ziel. Verkaufe hier exakt 50% deiner Position (Risk-Recycling) und ziehe den restlichen Stop auf Break-Even.")
        table.cell(cp, 1, r, f_p(tp_price), bgcolor=color.rgb(30,30,30), text_color=color.lime, text_size=cp_txt_main)
        r += 1
    if show_sl
        table.cell(cp, 0, r, "🏁 Stopp-Loss (SL)", bgcolor=color.rgb(50,50,50), text_color=color.orange, text_size=cp_txt_main, tooltip="Institutioneller Stop-Loss (1.0x ATR). Schützt vor Rauschen und Gaps.")
        table.cell(cp, 1, r, f_p(sl_price), bgcolor=color.rgb(30,30,30), text_color=color.orange, text_size=cp_txt_main)
        r += 1
    if show_runner
        table.cell(cp, 0, r, "🏃 Runner-Target", bgcolor=color.rgb(50,50,50), text_color=ema_col, text_size=cp_txt_main, tooltip="Dein Trailing-Radar für den 50% Runner. Wenn der heutige Tages-Schlusskurs diese EMA 21 Linie bricht, schließt du den gesamten Rest.")
        table.cell(cp, 1, r, ema_str, bgcolor=color.rgb(30,30,30), text_color=ema_col, text_size=cp_txt_main)
        r += 1

    // ZUSATZ-INFO Gruppe
    if grp_zusatz
        table.cell(cp, 0, r, "--- ZUSATZ-INFO (v20.7) ---", bgcolor=color.rgb(20,20,20), text_color=color.gray, text_size=cp_txt_sep, text_halign=text.align_center)
        table.merge_cells(cp, 0, r, 1, r)
        r += 1
    if show_bbzone
        table.cell(cp, 0, r, "🔭 Bollinger Zone", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="14-Punkte-System: LONG ZONE/EXTREME = Long erlaubt, SHORT ZONE/EXTREME = Short erlaubt. Im Scharf-Modus automatisch übergangen.")
        table.cell(cp, 1, r, bc_txt, bgcolor=bc_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_squeeze
        table.cell(cp, 0, r, "🗜️ BB Squeeze", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="v20.7: Bollinger Band Breite als % des Kurses. SQUEEZE (<3%) = Energie baut sich auf, guter Dip-Buy Kontext. EXPANSION (>8%) = Vorsicht, Bänder weiten sich, Dip-Buy riskanter.")
        table.cell(cp, 1, r, squeeze_txt, bgcolor=squeeze_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    if show_rsveto
        table.cell(cp, 0, r, "💪 RS-Veto Status", bgcolor=color.rgb(40,40,40), text_color=color.silver, text_size=cp_txt_main, tooltip="v20.7: Relative Stärke als Veto für Golden & AKJ Elite. Wenn Aktie ihren Sektor underperformt (RS = SCHWACH) können nur FEUER-Signale feuern — kein GOLDEN oder ELITE.")
        table.cell(cp, 1, r, rs_veto_txt, bgcolor=rs_veto_bg, text_color=color.white, text_size=cp_txt_main)
        r += 1
    int _done = r  // Cockpit-Ende: verhindert Pine-v6 Block-Fehler

// ==========================================
// --- 10. VISUALS & ALARME ---
// ==========================================
var line l_sp = na, var line l_sl = na, var line l_tp = na
var label lbl_sp = na, var label lbl_sl = na, var label lbl_tp = na
if barstate.islast and w_trend != 0
    line.delete(l_sp), line.delete(l_sl), line.delete(l_tp), label.delete(lbl_sp), label.delete(lbl_sl), label.delete(lbl_tp)
    l_sp := line.new(bar_index, sp_price, bar_index + 5, sp_price, color=color.yellow, width=1, style=line.style_dashed)
    l_sl := line.new(bar_index, sl_price, bar_index + 5, sl_price, color=color.red, width=1)
    l_tp := line.new(bar_index, tp_price, bar_index + 5, tp_price, color=color.lime, width=1)
    lbl_sp := label.new(bar_index + 5, sp_price, "🎯 Entry", color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)
    lbl_sl := label.new(bar_index + 5, sl_price, "🏁 Stop (1.0x ATR)", color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)
    lbl_tp := label.new(bar_index + 5, tp_price, "💸 TP", color=color.lime, textcolor=color.black, style=label.style_label_left, size=size.small)

// ==========================================
// --- 11. ALARMSYSTEM (Zero-Latency Sync) ---
// ==========================================

string tac_txt = "STATUS: NO SIGNAL"
if isAKJSignal_l
    tac_txt := "AKJ_ELITE_LONG"
else if isAKJSignal_s
    tac_txt := "AKJ_ELITE_SHORT"
else if trigger_golden_l
    tac_txt := "GOLDEN_LONG"
else if trigger_golden_s
    tac_txt := "GOLDEN_SHORT"
else if trigger_feuer_l
    tac_txt := "FEUER_LONG"
else if trigger_feuer_s
    tac_txt := "FEUER_SHORT"
else if trigger_lauern_l
    tac_txt := "LAUERN_LONG"
else if trigger_lauern_s
    tac_txt := "LAUERN_SHORT"

bool is_upgrade_l = (last_tac_txt == "FEUER_LONG" or last_tac_txt == "LAUERN_LONG") and (tac_txt == "GOLDEN_LONG" or tac_txt == "AKJ_ELITE_LONG")
bool is_upgrade_s = (last_tac_txt == "FEUER_SHORT" or last_tac_txt == "LAUERN_SHORT") and (tac_txt == "GOLDEN_SHORT" or tac_txt == "AKJ_ELITE_SHORT")
bool is_upgrade = is_upgrade_l or is_upgrade_s

bool is_action_status = (tac_txt == "AKJ_ELITE_LONG" or tac_txt == "AKJ_ELITE_SHORT" or tac_txt == "FEUER_LONG" or tac_txt == "FEUER_SHORT" or tac_txt == "GOLDEN_LONG" or tac_txt == "GOLDEN_SHORT")
bool status_is_new = (tac_txt != last_fired_status)

bool can_alert = barstate.isrealtime and cooldown_over and is_action_status and status_is_new

string wpr_s = str.tostring(nz(d_wpr), "#.#")
string shares_l_str = nz(shares_l) > 0 ? str.tostring(nz(shares_l)) : "0 [HINWEIS] Risiko für 1 Stück aktuell > Budget. Manueller Check nötig."
string shares_s_str = nz(shares_s) > 0 ? str.tostring(nz(shares_s)) : "0 [HINWEIS] Risiko für 1 Stück aktuell > Budget. Manueller Check nötig."
string rt_prefix = barstate.isconfirmed ? "[EOD]" : "[REALTIME]"

// Star Ticker Logic
float eur_lauern = (w_lauern + l_lauern) > 0 ? (p_lauern / (w_lauern + l_lauern)) * active_risk_display : 0.0
float eur_feuer = (w_feuer + l_feuer) > 0 ? (p_feuer / (w_feuer + l_feuer)) * active_risk_display : 0.0
float eur_golden = (w_golden + l_golden) > 0 ? (p_golden / (w_golden + l_golden)) * active_risk_display : 0.0

string star_p_l = eur_lauern > 0 ? "🔥 [STAR-TICKER] " : ""
string star_p_f = eur_feuer > 0 ? "🔥 [STAR-TICKER] " : ""
string star_p_g = eur_golden > 0 ? "🔥 [STAR-TICKER] " : ""

if can_alert
    last_fired_status := tac_txt
    last_fired_time := timenow

    string shares_str = (tac_txt == "AKJ_ELITE_LONG" or tac_txt == "GOLDEN_LONG" or tac_txt == "FEUER_LONG" or tac_txt == "LAUERN_LONG") ? shares_l_str : shares_s_str
    
    string rom_str = str.tostring(nz(active_risk_display), "#.##") + " €"
    string anc_str = str.tostring(nz(anchor_bars)) + " Bars ago"
    string ema_str = "EMA 21: " + f_p(ema21)

    string triggerReason = ""
    if (tac_txt == "AKJ_ELITE_LONG" or tac_txt == "GOLDEN_LONG" or tac_txt == "FEUER_LONG" or tac_txt == "LAUERN_LONG")
        triggerReason := "GRUND: Dieser Alarm bimmelt, weil die Aktie in Weinstein Stage 2 (Aufwärtstrend) ist und der Williams %R (4) mit " + wpr_s + " einen statistisch günstigen Rücksetzer (Dip) signalisiert."
    else if (tac_txt == "AKJ_ELITE_SHORT" or tac_txt == "GOLDEN_SHORT" or tac_txt == "FEUER_SHORT" or tac_txt == "LAUERN_SHORT")
        triggerReason := "GRUND: Dieser Alarm bimmelt, weil die Aktie in Weinstein Stage 4 (Abwärtstrend) ist und der Williams %R (4) mit " + wpr_s + " eine kurzfristige Erholung (Rebound) für den Einstieg anzeigt."

    string alert_msg = triggerReason + "\n" +
      "--- COCKPIT DATEN ---\n" +
      "ZEITPUNKT: " + str.format_time(timenow, "yyyy-MM-dd HH:mm:ss", "UTC") + "\n" +
      "TICKER: " + syminfo.ticker + "\n" +
      header_txt + "\n\n" +
      "--- MARKT-KONTEXT ---\n" +
      "Sektor: " + sec_txt + "\n" +
      "Rel. Stärke: " + rs_txt + "\n" +
      "Weinstein Stage: " + ws_txt + "\n\n" +
      "--- TREND-ANALYSE (v20.5) ---\n" +
      "Wochentrend: " + wt_txt + "\n" +
      "Tagestrend: " + dt_txt + "\n\n" +
      "--- SNIPER METRIKEN ---\n" +
      "Risk-O-Meter (1R): " + rom_str + "\n" +
      "Risk-Mode (Adaptiv): " + risk_mode_txt + "\n" +
      "Anchor-Info: " + anc_str + "\n" +
      "Vacuum Quality: " + vacuum_qual + "\n" +
      "Momentum (WPR): " + wpr_s + "\n" +
      "Kerzenregel: " + c_txt + "\n" +
      "Stopversicherung: " + str.tostring(nz(stop_density), "#.#") + "%\n" +
      "TP Widerstand: " + str.tostring(nz(tp_density), "#.#") + "%\n\n" +
      "--- ORDER-MATRIX ---\n" +
      "Stoppreis (SP): " + f_p(sp_price) + "\n" +
      "Limitpreis (LP): " + f_p(lp_price) + "\n" +
      "Anzahl (Stk): " + shares_str + "\n" +
      "TP (Teilverkauf): " + f_p(tp_price) + "\n" +
      "Stopp-Loss (SL): " + f_p(sl_price) + "\n" +
      "Runner-Target: " + ema_str + "\n\n" +
      "--- ZUSATZ-INFO ---\n" +
      "Bollinger Zone: " + bc_txt + "\n" +
      "BB Squeeze: " + squeeze_txt + "\n" +
      "RS-Veto: " + (rs_ok_for_premium ? "OK" : "AKTIV (RS SCHWACH)") + "\n" +
      "ATR%: " + str.tostring(atr_pct, "#.##") + "% | Min.Wall FEUER: " + str.tostring(dyn_min_stop_feuer, "#.##") + "% | Min.Wall GOLDEN: " + str.tostring(dyn_min_stop_golden, "#.##") + "%" +
      "\n\n--- JSON PAYLOAD ---\n" +
      "{\"ticker\":\"" + syminfo.ticker + "\",\"signal\":\"" + tac_txt + "\"," +
      "\"sp\":" + f_p(sp_price) + ",\"sl\":" + f_p(sl_price) + ",\"tp\":" + f_p(tp_price) + "," +
      "\"shares\":" + str.tostring(nz(shares)) + ",\"risk_eur\":" + str.tostring(nz(active_risk_display), "#.##") + "," +
      "\"wpr\":" + str.tostring(nz(d_wpr), "#.#") + ",\"stop_wall\":" + str.tostring(nz(stop_density), "#.##") + "," +
      "\"tp_resistance\":" + str.tostring(nz(tp_density), "#.##") + ",\"rs_status\":\"" + rs_txt + "\",\"bb_squeeze\":\"" + squeeze_txt + "\"}"

    if tac_txt == "AKJ_ELITE_LONG"
        alert(star_p_g + "💎 AKJ ELITE SIGNAL 💎 🌟 GOLDEN SETUP LONG 🌟 " + syminfo.ticker + "\n" + alert_msg, alert.freq_once_per_bar_close)
    else if tac_txt == "AKJ_ELITE_SHORT"
        alert(star_p_g + "💎 AKJ ELITE SIGNAL 💎 🌟 GOLDEN SETUP SHORT 🌟 " + syminfo.ticker + "\n" + alert_msg, alert.freq_once_per_bar_close)
    else if tac_txt == "GOLDEN_LONG"
        alert(star_p_g + "🌟 GOLDEN SETUP LONG 🌟 " + syminfo.ticker + "\n" + alert_msg, alert.freq_once_per_bar)
    else if tac_txt == "GOLDEN_SHORT"
        alert(star_p_g + "🌟 GOLDEN SETUP SHORT 🌟 " + syminfo.ticker + "\n" + alert_msg, alert.freq_once_per_bar)
    else if tac_txt == "FEUER_LONG"
        alert(star_p_f + "🟢 FEUER FREI LONG 🟢 " + syminfo.ticker + "\n" + alert_msg, alert.freq_once_per_bar)
    else if tac_txt == "FEUER_SHORT"
        alert(star_p_f + "🟢 FEUER FREI SHORT 🟢 " + syminfo.ticker + "\n" + alert_msg, alert.freq_once_per_bar)

if tac_txt != "STATUS: NO SIGNAL"
    last_tac_txt := tac_txt

// Keep logic clean: if it goes back to NO SIGNAL, we allow re-arming of the alarms
if tac_txt == "STATUS: NO SIGNAL"
    last_fired_status := ""
    last_tac_txt := "STATUS: NO SIGNAL"

// ==========================================
// --- 12. PINE SCREENER EXPORTS ---
// ==========================================
// Diese Werte lesen wir als Liste für Watchlisten mit 1000+ Aktien aus!
int screener_code = 0
if tac_txt == "AKJ_ELITE_LONG"
    screener_code := 4
else if tac_txt == "GOLDEN_LONG"
    screener_code := 3
else if tac_txt == "FEUER_LONG"
    screener_code := 2
else if tac_txt == "LAUERN_LONG"
    screener_code := 1
else if tac_txt == "LAUERN_SHORT"
    screener_code := -1
else if tac_txt == "FEUER_SHORT"
    screener_code := -2
else if tac_txt == "GOLDEN_SHORT"
    screener_code := -3
else if tac_txt == "AKJ_ELITE_SHORT"
    screener_code := -4

// "Sniper Status" (Zeigt die Stärke & Richtung an: +4 bis -4)
plot(screener_code, title="Sniper Status (+4=Elite L, -4=Elite S)", color=color.new(color.white, 100), display=display.data_window)

// Optionale Zusatzfilter für den Pine Screener (0 = Nein, 1 = Ja)
plot(isAKJSignal_l or isAKJSignal_s ? 1 : 0, title="Ist Elite", color=color.new(color.white, 100), display=display.none)
plot(trigger_feuer_l or trigger_feuer_s or trigger_golden_l or trigger_golden_s ? 1 : 0, title="Ist Feuer Frei", color=color.new(color.white, 100), display=display.none)