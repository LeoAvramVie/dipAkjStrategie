//@version=6
indicator("AKJ 2.0 Sniper-Commander v20.4", overlay=true, max_labels_count=500)

// ==========================================
// --- 1. INPUTS ---
// ==========================================
group_rm         = "Risikomanagement"
risk_per_trade   = input.float(150.0, "Risiko pro Trade (1R)", group=group_rm)
limit_offset_pct = input.float(0.2, "Limit-Offset (%)", group=group_rm)
puffer_ticks     = input.int(2, "Puffer in Ticks", group=group_rm)

group_strat      = "MK-Strategie Parameter"
bb_len           = input.int(10, "Bollinger Länge", group=group_strat)
bb_mult          = input.float(1.0, "Bollinger Multiplikator", group=group_strat)
wpr_len          = input.int(4, "Williams %R Länge", group=group_strat)

group_vol_filter = "Volumen Filter (v18.8)"
vol_timeframe    = input.timeframe("240", "Volumen Timeframe (Standard 4H)", group=group_vol_filter)
vol_lookback     = input.int(100, "Volume Lookback Periode", group=group_vol_filter)
min_stop_density = input.float(10.0, "Min. Stop-Versicherung (%)", group=group_vol_filter)
max_tp_density   = input.float(8.0, "Max. TP-Widerstand (%)", group=group_vol_filter)
min_vol_ratio    = input.float(1.5, "Min. Ratio (Stop vs TP) für Flex-Golden", group=group_vol_filter)

group_rs         = "Sektor & Relative Stärke (v20.0)"
use_auto_etf     = input.bool(true, "Auto-Detect Sektor (Mega-Caps)", group=group_rs)
user_etf         = input.symbol("SPY", "Manueller Sektor-ETF (Fallback)", group=group_rs)

// Williams %R (Absolute Skala 0-100)
d_wpr = math.abs(ta.wpr(wpr_len))

// ==========================================
// --- 2. WOCHEN-DATA (Sticky & Strict) ---
// ==========================================
f_bb_w_hist() => 
    basis = ta.sma(close, bb_len)
    dev = ta.stdev(close, bb_len) * bb_mult
    // [1] = Letzte geschlossene Woche, [2] = Vorletzte geschlossene Woche
    [close[1], basis[1] + dev[1], basis[1] - dev[1], close[2], basis[2] + dev[2], basis[2] - dev[2], ta.sma(close, 30)[1], ta.sma(close, 30)[2]]

[w_cl_1, w_up_1, w_lo_1, w_cl_2, w_up_2, w_lo_2, w_sma30_1, w_sma30_2] = request.security(syminfo.tickerid, "W", f_bb_w_hist(), lookahead=barmerge.lookahead_off)

var int w_trend = 0 
// Trend-Bestätigung strikt ohne Lookahead-Bias
if w_cl_1 > w_up_1 and w_cl_2 > w_up_2
    w_trend := 1
else if w_cl_1 < w_lo_1 and w_cl_2 < w_lo_2
    w_trend := -1

// Weinstein Stage Logic (SMA 30)
int weinstein_stage = 0
if w_cl_1 > w_sma30_1 and w_sma30_1 > w_sma30_2
    weinstein_stage := 2
else if w_cl_1 < w_sma30_1 and w_sma30_1 < w_sma30_2
    weinstein_stage := 4

string ws_txt = weinstein_stage == 2 ? "STAGE 2 OK Long ✅" : weinstein_stage == 4 ? "STAGE 4 OK Short ✅" : "SEITWÄRTS"
color  ws_bg  = weinstein_stage == 2 ? color.blue : weinstein_stage == 4 ? color.red : color.rgb(30, 30, 30)

// ==========================================
// --- 3. TAGES-LOGIK (Sticky State Machine) ---
// ==========================================
[d_basis, d_up, d_lo] = ta.bb(close, bb_len, bb_mult)

var bool setup_strict_long  = false
var bool setup_strict_short = false

// Entstehung (2 Tage außerhalb)
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_long := true
if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_short := true

// Invalidierung (2 Tage Gegenseite)
if close[1] < d_lo[1] and close[2] < d_lo[2]
    setup_strict_long := false
if close[1] > d_up[1] and close[2] > d_up[2]
    setup_strict_short := false

// Radar-Zustand (Persistent für UI)
bool is_in_radar_long  = close[1] > d_up[1] or setup_strict_long
bool is_in_radar_short = close[1] < d_lo[1] or setup_strict_short

// ==========================================
// --- 4. PREIS-BERECHNUNG ---
// ==========================================
puffer = syminfo.mintick * puffer_ticks
float sp_price = w_trend == -1 ? low - puffer : high + puffer
float sl_price = w_trend == -1 ? high + puffer : low - puffer
float risk_val = math.abs(sp_price - sl_price)
int   shares   = risk_val > 0 ? math.floor(risk_per_trade / risk_val) : 0
float lp_price = w_trend == -1 ? sp_price * (1 - limit_offset_pct / 100) : sp_price * (1 + limit_offset_pct / 100)
float tp_price = w_trend == -1 ? sp_price - risk_val : sp_price + risk_val

// ==========================================
// --- 5. VOLUMEN-STRUKTUR (Multi-Timeframe / 4H) ---
// ==========================================
// Funktion läuft komplett im Ziel-Timeframe (z.B. 4H)
f_calc_tf_vol(sp, sl, tp, do_calc) =>
    float s_dens = 0.0
    float t_dens = 0.0
    if do_calc
        float zone_vol_s = 0.0
        float zone_vol_t = 0.0
        float total_v    = 0.0
        float upper_s = math.max(sp, sl), float lower_s = math.min(sp, sl)
        float upper_t = math.max(sp, tp), float lower_t = math.min(sp, tp)
        for i = 0 to vol_lookback - 1
            float bar_h = high[i], float bar_l = low[i], float bar_vol = volume[i]
            total_v += bar_vol
            float bar_range = bar_h - bar_l
            if bar_range > 0
                float intersect_s = math.max(0, math.min(bar_h, upper_s) - math.max(bar_l, lower_s))
                zone_vol_s += bar_vol * (intersect_s / bar_range)
                float intersect_t = math.max(0, math.min(bar_h, upper_t) - math.max(bar_l, lower_t))
                zone_vol_t += bar_vol * (intersect_t / bar_range)
        // Dev-Check: Absolute Sicherheit gegen Runtime-Errors (Division by zero)
        if total_v > 0
            s_dens := (zone_vol_s / total_v) * 100
            t_dens := (zone_vol_t / total_v) * 100
    [s_dens, t_dens]

// CPU-Optimierung (Lazy Evaluation)
bool needs_vol_calc = is_in_radar_long or is_in_radar_short or barstate.islast

// Zieht sich die Volumen-Dichte IMMER aus dem gewählten Timeframe (Standard: 4H)
[stop_density, tp_density] = request.security(syminfo.tickerid, vol_timeframe, f_calc_tf_vol(sp_price, sl_price, tp_price, needs_vol_calc))

// ==========================================
// --- 6. SIGNAL-IDENTIFIKATION ---
// ==========================================
// Sniper (Technik) - Inkl. Doji & Band-Check (MK 4.7 / 5.6)
// Long-Signal NUR wenn Kerze INNERHALB des unteren Bandes schließt (close > d_lo)
bool long_trigger = d_wpr >= 80 and close < open and close != open and close > d_lo
bool is_sniper_long  = w_trend == 1  and setup_strict_long  and long_trigger

// Short-Signal NUR wenn Kerze INNERHALB des oberen Bandes schließt (close < d_up)
bool short_trigger = d_wpr <= 20 and close > open and close != open and close < d_up
bool is_sniper_short = w_trend == -1 and setup_strict_short and short_trigger

// Golden (Technik + Volumen - Flex-Ratio gegen "Statistik-Starre")
// Brick Wall Cap (v20.4): Golden Setup invalidieren, wenn TP-Mauer extrem hoch ist (> 150% des eingestellten Max-Limits).
float density_ratio = tp_density > 0 ? (stop_density / tp_density) : (stop_density > 0 ? 10.0 : 0.0)
float brick_wall_cap = max_tp_density * 1.5
bool vol_condition  = (stop_density >= min_stop_density and tp_density <= max_tp_density) or (density_ratio >= min_vol_ratio and stop_density >= min_stop_density * 0.7 and tp_density <= brick_wall_cap)

bool is_golden_long  = is_sniper_long  and vol_condition
bool is_golden_short = is_sniper_short and vol_condition

// Radar (Lauer-Zone)
bool is_lauern_long   = w_trend == 1  and is_in_radar_long  and d_wpr >= 70 and not is_sniper_long
bool is_lauern_short  = w_trend == -1 and is_in_radar_short and d_wpr <= 30 and not is_sniper_short

// ==========================================
// --- 7. SEKTOR & RELATIVE STÄRKE ---
// ==========================================
f_get_auto_sector() =>
    string etf   = "SPY"
    string sec   = syminfo.sector
    string ind   = syminfo.industry
    string sname = sec != "" ? sec : "S&P 500 Index"
    
    if use_auto_etf
        if ind == "Aerospace & Defense"
            etf := "ITA"
            sname := "Rüstung & Aero"
        else if ind == "Semiconductors"
            etf := "SMH"
            sname := "Halbleiter"
        else if sec == "Electronic Technology" or sec == "Technology Services"
            etf := "XLK"
        else if sec == "Energy Minerals"
            etf := "XLE"
        else if sec == "Finance" or sec == "Commercial Services"
            etf := "XLF"
        else if sec == "Health Technology" or sec == "Health Services"
            etf := "XLV"
        else if sec == "Producer Manufacturing" or sec == "Industrial Services"
            etf := "XLI"
        else if sec == "Consumer Durables" or sec == "Retail Trade" or sec == "Consumer Services"
            etf := "XLY"
        else if sec == "Consumer Non-Durables" or sec == "Process Industries"
            etf := "XLP"
        else if sec == "Non-Energy Minerals"
            etf := "XLB"
        else if sec == "Communications"
            etf := "XLC"
        else if sec == "Utilities"
            etf := "XLU"
        else if sec == "Real Estate"
            etf := "XLRE"
    
    if not use_auto_etf or etf == "SPY"
        etf := user_etf
        sname := user_etf == "SPY" ? "S&P 500 Index" : (sec != "" ? sec : "Index/ETF")
        
    [etf, sname]

[sector_ticker, sector_name] = f_get_auto_sector()

[etf_c, etf_sma, etf_c20] = request.security(sector_ticker, "1D", [close, ta.sma(close, 10), close[20]], lookahead=barmerge.lookahead_off)

bool sector_long = etf_c > etf_sma
string sec_txt = sector_name + " (" + sector_ticker + ")"
color sec_bg = sector_long ? color.blue : color.red

float stock_perf = close[20] != 0 ? ((close - close[20]) / close[20]) * 100 : 0.0
float etf_perf   = etf_c20 != 0 ? ((etf_c - etf_c20) / etf_c20) * 100 : 0.0
float perf_diff  = stock_perf - etf_perf

string rs_txt = perf_diff > 2.0 ? "STARK" : perf_diff < -2.0 ? "SCHWACH" : "MITTEL"
color  rs_bg  = perf_diff > 2.0 ? color.blue : perf_diff < -2.0 ? color.red : color.rgb(30, 30, 30)


// ==========================================
// --- 8. UI LOGIK & FARBEN ---
// ==========================================
color color_himmelblau = color.rgb(0, 191, 255), color_hellrot = color.rgb(240, 128, 128), color_gold = color.rgb(13, 255, 0)

string w_txt = w_trend == 1 ? "LONG" : w_trend == -1 ? "SHORT" : "---"
color  w_bg  = w_trend == 1 ? color.blue : w_trend == -1 ? color.red : color.rgb(30, 30, 30)

string d_txt = setup_strict_long ? "LONG" : setup_strict_short ? "SHORT" : (is_lauern_long or is_lauern_short) ? "LAUERN" : ""
color  d_bg  = setup_strict_long ? color.blue : setup_strict_short ? color.red : (is_lauern_long or is_lauern_short) ? color.yellow : color.rgb(30, 30, 30)

color wpr_bg = d_wpr >= 80 ? color.blue : d_wpr >= 70 ? color_himmelblau : d_wpr <= 20 ? color.red : d_wpr <= 30 ? color_hellrot : color.rgb(30, 30, 30)

bool is_any_action = is_sniper_long or is_sniper_short or is_golden_long or is_golden_short
color action_color = (is_sniper_long or is_golden_long) ? color.blue : color.red

string c_txt = ""
color  c_bg  = color.rgb(30, 30, 30)
if w_trend == 1
    c_txt := close < open ? "OK ✅" : "WAIT ⏳"
    c_bg  := close < open ? color.blue : color.rgb(30, 30, 30)
else if w_trend == -1
    c_txt := close > open ? "OK ✅" : "WAIT ⏳"
    c_bg  := close > open ? color.red : color.rgb(30, 30, 30)

if is_any_action
    ws_bg := action_color, w_bg := action_color, d_bg := action_color, wpr_bg := action_color, c_bg := action_color

// ==========================================
// --- 9. COCKPIT UI ---
// ==========================================
var table cp = table.new(position.top_right, 2, 20, border_width=0)
f_p(val) => na(val) ? "-" : str.tostring(val, "#.##")

if barstate.islast
    table.cell(cp, 0, 0, "", bgcolor=color.new(color.black, 100)), table.cell(cp, 1, 0, "", bgcolor=color.new(color.black, 100))
    table.cell(cp, 0, 1, "", bgcolor=color.new(color.black, 100)), table.cell(cp, 1, 1, "", bgcolor=color.new(color.black, 100))

    string tac_txt = is_golden_long ? "!!! GOLDEN (LONG 🔵) !!!" : is_golden_short ? "!!! GOLDEN (SHORT 🔴) !!!" : is_sniper_long ? "!!! FEUER FREI (LONG 🔵) !!!" : is_sniper_short ? "!!! FEUER FREI (SHORT 🔴) !!!" : is_lauern_long ? "LAUERN (LONG 🔵)" : is_lauern_short ? "LAUERN (SHORT 🔴)" : "Keine"
    color tac_bg = is_golden_long or is_golden_short ? color_gold : is_any_action ? action_color : (is_lauern_long or is_lauern_short) ? color.yellow : color.rgb(20, 20, 20)
    table.cell(cp, 0, 2, "Strategie", bgcolor=color.rgb(80, 80, 80), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 2, tac_txt, bgcolor=tac_bg, text_color=(tac_bg == color.yellow or tac_bg == color_gold) ? color.black : color.white, text_size=size.normal, text_halign=text.align_right)

    table.cell(cp, 0, 3, "🌍Sektor", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 3, sec_txt, bgcolor=sec_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 4, "💪Rel. Stärke", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 4, rs_txt, bgcolor=rs_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)

    table.cell(cp, 0, 5, "📈Weinstein Stage", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 5, ws_txt, bgcolor=ws_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)

    table.cell(cp, 0, 6, "📈Wochentrend", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 6, w_txt, bgcolor=w_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 7, "📈Tagstrend", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 7, d_txt, bgcolor=d_bg, text_color=d_bg == color.yellow ? color.black : color.white, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 8, "⚡Williams %R", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 8, str.tostring(d_wpr, "#.#"), bgcolor=wpr_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)

    table.cell(cp, 0, 9, "🕯️Kerzenregel", bgcolor=color.rgb(40, 40, 40), text_color=color.silver, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 9, c_txt, bgcolor=c_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)

    table.cell(cp, 0, 10, "🎯Stoppreis", bgcolor=color.rgb(50, 50, 50), text_color=color.yellow, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 10, f_p(sp_price), bgcolor=color.rgb(30, 30, 30), text_color=color.yellow, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 11, "🤝LimitPreis", bgcolor=color.rgb(50, 50, 50), text_color=color.yellow, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 11, f_p(lp_price), bgcolor=color.rgb(30, 30, 30), text_color=color.yellow, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 12, "🔢Anzahl", bgcolor=color.rgb(50, 50, 50), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 12, str.tostring(shares), bgcolor=color.rgb(30, 30, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 13, "💸TP - Teilverkauf", bgcolor=color.rgb(50, 50, 50), text_color=color.lime, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 13, f_p(tp_price), bgcolor=color.rgb(30, 30, 30), text_color=color.lime, text_size=size.normal, text_halign=text.align_right)
    table.cell(cp, 0, 14, "🏁 Stopp-Loss", bgcolor=color.rgb(50, 50, 50), text_color=color.orange, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 14, f_p(sl_price), bgcolor=color.rgb(30, 30, 30), text_color=color.orange, text_size=size.normal, text_halign=text.align_right)

    color s_v_bg = stop_density >= min_stop_density ? color.rgb(10, 60, 10) : stop_density > (min_stop_density / 2) ? color.rgb(60, 40, 10) : color.rgb(60, 10, 10)
    table.cell(cp, 0, 15, "🛡️Stopversicherung", bgcolor=color.rgb(40, 40, 40), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 15, str.tostring(stop_density, "#.#") + "%", bgcolor=s_v_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    
    color t_v_bg = tp_density <= max_tp_density ? color.rgb(10, 60, 10) : tp_density < (max_tp_density * 1.5) ? color.rgb(60, 40, 10) : color.rgb(60, 10, 10)
    table.cell(cp, 0, 16, "🚧TP Widerstand", bgcolor=color.rgb(40, 40, 40), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(cp, 1, 16, str.tostring(tp_density, "#.#") + "%", bgcolor=t_v_bg, text_color=color.white, text_size=size.normal, text_halign=text.align_right)

// ==========================================
// --- 10. VISUALS & ALARME ---
// ==========================================
var line l_sp = na, var line l_sl = na, var line l_tp = na
var label lbl_sp = na, var label lbl_sl = na, var label lbl_tp = na
if barstate.islast and w_trend != 0
    line.delete(l_sp), line.delete(l_sl), line.delete(l_tp), label.delete(lbl_sp), label.delete(lbl_sl), label.delete(lbl_tp)
    l_sp := line.new(bar_index, sp_price, bar_index + 5, sp_price, color=color.yellow, width=1, style=line.style_dashed)
    l_sl := line.new(bar_index, sl_price, bar_index + 5, sl_price, color=color.red, width=1)
    l_tp := line.new(bar_index, tp_price, bar_index + 5, tp_price, color=color.lime, width=1)
    lbl_sp := label.new(bar_index + 5, sp_price, "🎯Buy", color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)
    lbl_sl := label.new(bar_index + 5, sl_price, "🏁Stop", color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)
    lbl_tp := label.new(bar_index + 5, tp_price, " 💸 Teilverkauf", color=color.lime, textcolor=color.black, style=label.style_label_left, size=size.small)



if barstate.isrealtime
    if is_golden_long or is_golden_short
        alert("🏆 GOLDEN SETUP " + syminfo.ticker + ": In: " + f_p(sp_price) + " | Qty: " + str.tostring(shares), alert.freq_once_per_bar)
    else if is_sniper_long or is_sniper_short
        alert("🎯 SNIPER " + syminfo.ticker + ": Feuer frei! In: " + f_p(sp_price), alert.freq_once_per_bar)
    else if is_lauern_long or is_lauern_short
        alert("📡 RADAR " + syminfo.ticker + ": Zone erreicht. Lauer-Modus!", alert.freq_once_per_bar)